---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.svelte';
import Card from '../components/Card.svelte';
import Badge from '../components/Badge.svelte';
---

<BaseLayout title="Styleguide | Brazilian Modernism">
  <div class="styleguide-container">
    <header>
      <h1>Brazilian Modernism Styleguide</h1>
      <p class="tracked-caps">Doctrine: Curva & Concreto</p>
    </header>

    <section>
      <h2>Typography</h2>
      <p>Modernist rhythm. Generous line-heights. Tracked caps for labels.</p>
      <div class="typo-sample">
        <h1>Heading 1: Bossa Nova</h1>
        <h2>Heading 2: Athos Bulcão</h2>
        <h3>Heading 3: Volpi</h3>
        <p>This is standard paragraph text. It has generous line-height to make reading comfortable, simulating the breathability of modernist architecture.</p>
        <p class="tracked-caps">This is tracked caps text, suitable for small labels or badges.</p>
      </div>
    </section>

    <section>
      <h2>Colors</h2>
      <div class="color-grid">
        <div class="color-swatch" style="background: var(--color-bg); color: var(--color-text);">
          <div class="color-name tracked-caps">Background</div>
          <div class="color-hex">#F4EFE4</div>
        </div>
        <div class="color-swatch" style="background: var(--color-surface); color: var(--color-text);">
          <div class="color-name tracked-caps">Surface</div>
          <div class="color-hex">#EAE2CE</div>
        </div>
        <div class="color-swatch" style="background: var(--color-accent); color: var(--color-bg);">
          <div class="color-name tracked-caps">Accent (Volpi Red)</div>
          <div class="color-hex">#C2281F</div>
        </div>
        <div class="color-swatch" style="background: var(--color-azul); color: var(--color-bg);">
          <div class="color-name tracked-caps">Azul (Focus/Info)</div>
          <div class="color-hex">#1F6FA8</div>
        </div>
        <div class="color-swatch" style="background: var(--color-ouro); color: var(--color-text);">
          <div class="color-name tracked-caps">Ouro (Warning)</div>
          <div class="color-hex">#D8A43A</div>
        </div>
        <div class="color-swatch" style="background: var(--color-verde); color: var(--color-bg);">
          <div class="color-name tracked-caps">Verde (Success)</div>
          <div class="color-hex">#3F7A4E</div>
        </div>
      </div>
    </section>

    <section>
      <h2>Components</h2>

      <div class="component-demo">
        <h3>Buttons (Curve)</h3>
        <p>Parabolic curves for UI chrome.</p>
        <div class="demo-row">
          <Button>Primary Action</Button>
          <Button onclick={() => alert('Clicked!')}>Click Me</Button>
        </div>
      </div>

      <div class="component-demo">
        <h3>Badges (Concrete)</h3>
        <p>Sharp geometry for data.</p>
        <div class="demo-row">
          <Badge variant="azul">Info Badge</Badge>
          <Badge variant="ouro">Warning Badge</Badge>
          <Badge variant="verde">Success Badge</Badge>
        </div>
      </div>

      <div class="component-demo">
        <h3>Cards & Patterns (Concrete + Athos Bulcão)</h3>
        <p>Sharp geometry for containers, with subtle CSS patterns.</p>

        <div class="card-grid">
          <Card>
            <h4>Standard Card</h4>
            <p>Plain surface card with sharp corners.</p>
            <div class="mt-4"><Badge variant="azul">Normal</Badge></div>
          </Card>

          <Card pattern="triangles">
            <h4>Triangles Pattern</h4>
            <p>Card with Bulcão triangles pattern in background.</p>
            <div class="mt-4"><Button>Action</Button></div>
          </Card>

          <Card pattern="stripes">
            <h4>Stripes Pattern</h4>
            <p>Card with Bulcão stripes pattern in background.</p>
            <div class="mt-4"><Badge variant="ouro">Warning</Badge></div>
          </Card>

          <Card pattern="moons">
            <h4>Half-moons Pattern</h4>
            <p>Card with Bulcão half-moons pattern in background.</p>
            <div class="mt-4"><Badge variant="verde">Success</Badge></div>
          </Card>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .styleguide-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  header {
    margin-bottom: 4rem;
    border-bottom: 2px solid var(--color-text);
    padding-bottom: 1rem;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }

  section {
    margin-bottom: 5rem;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: var(--color-accent);
  }

  h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .typo-sample {
    background-color: var(--color-surface);
    padding: 2rem;
  }

  .color-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .color-swatch {
    height: 120px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem;
    border: 1px solid rgba(0,0,0,0.1);
  }

  .color-name {
    font-weight: bold;
    margin-bottom: 0.25rem;
  }

  .color-hex {
    font-family: monospace;
    opacity: 0.8;
  }

  .component-demo {
    margin-bottom: 3rem;
  }

  .demo-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    background-color: var(--color-surface);
    padding: 2rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .mt-4 {
    margin-top: 1rem;
  }
</style>
