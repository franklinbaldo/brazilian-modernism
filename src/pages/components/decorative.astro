---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Stamp from '../../components/decorative/Stamp.svelte';
import Lambe from '../../components/decorative/Lambe.svelte';
import Sign from '../../components/decorative/Sign.svelte';
import Pennant from '../../components/decorative/Pennant.svelte';
import Bandeirinhas from '../../components/decorative/Bandeirinhas.svelte';
import Foliage from '../../components/decorative/Foliage.svelte';
import RiverMap from '../../components/decorative/RiverMap.svelte';
---

<BaseLayout title="Componentes decorativos | COBOGÓ">
  <aside aria-hidden="true" data-pattern="cobogo-losango" data-region="tile-sidebar"></aside>

  <header data-region="site-header">
    <nav>
      <ul><li><strong>COBOGÓ</strong></li></ul>
      <ul>
        <li><a href="/cobogo/">Home</a></li>
        <li><a href="/cobogo/manifesto/">Manifesto</a></li>
        <li><a href="/cobogo/componentes/">Components</a></li>
        <li><a href="/cobogo/patterns/">Patterns</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <header data-page-header>
      <hgroup>
        <h1>Componentes Decorativos</h1>
        <p>Elementos de interface que carregam sabor local e identidade brasileira de maneira não-funcional, apenas como tempero visual (Wave C).</p>
      </hgroup>
    </header>

    <section data-decorative-grid>
      <article>
        <figure>
          <Stamp text="APROVADO" date="24/09/2024" color="var(--azul)" rotation={12} />
          <Stamp />
        </figure>
        <header>
          <h2>Stamp</h2>
          <pre><code>{`import Stamp from 'cobogo/components/decorative/Stamp';

<Stamp text="APROVADO" color="var(--azul)" rotation={12} />
<Stamp /> <!-- Default (RECEBIDO, vermelho) -->`}</code></pre>
        </header>
      </article>

      <article>
        <figure data-bg="sunken">
          <Lambe kicker="Atenção" title="Trago o amor em 3 dias" color="amarelo" />
          <Lambe title="Festa na Rua" subtitle="A partir das 18h" color="vermelho" />
        </figure>
        <header>
          <h2>Lambe</h2>
          <pre><code>{`import Lambe from 'cobogo/components/decorative/Lambe';

<Lambe kicker="Atenção" title="Trago o amor..." color="amarelo" />
<Lambe title="Festa na Rua" subtitle="..." color="vermelho" />`}</code></pre>
        </header>
      </article>

      <article>
        <figure>
          <Sign text="Borracharia" accent="azul" />
          <Sign text="Bar do Luiz" accent="vermelho" />
        </figure>
        <header>
          <h2>Sign (Letreiro)</h2>
          <pre><code>{`import Sign from 'cobogo/components/decorative/Sign';

<Sign text="Borracharia" accent="azul" />
<Sign text="Bar do Luiz" accent="vermelho" />`}</code></pre>
        </header>
      </article>

      <article>
        <figure data-gap="lg">
          <Pennant text="Folia" color="azul" />
          <Pennant text="Festa" color="ocre" />
          <Pennant text="Luta" color="vermelho" />
        </figure>
        <header>
          <h2>Pennant (Flâmula)</h2>
          <pre><code>{`import Pennant from 'cobogo/components/decorative/Pennant';

<Pennant text="Folia" color="azul" />
<Pennant text="Festa" color="ocre" />`}</code></pre>
        </header>
      </article>

      <article data-span="full">
        <figure data-pad-top>
          <Bandeirinhas count={12} />
        </figure>
        <header>
          <h2>Bandeirinhas</h2>
          <pre><code>{`import Bandeirinhas from 'cobogo/components/decorative/Bandeirinhas';

<Bandeirinhas count={12} />`}</code></pre>
        </header>
      </article>

      <article>
        <figure data-stage="foliage">
          <Foliage position="top-left" size={150} />
          <Foliage position="bottom-right" color="var(--azul)" />
        </figure>
        <header>
          <h2>Foliage</h2>
          <pre><code>{`import Foliage from 'cobogo/components/decorative/Foliage';

<Foliage position="top-left" size={150} />
<Foliage position="bottom-right" color="var(--azul)" />`}</code></pre>
        </header>
      </article>

      <article>
        <figure data-stage="rivermap">
          <RiverMap color="var(--vermelho)" opacity={0.3} />
          <h3>Hero Content Here</h3>
        </figure>
        <header>
          <h2>RiverMap</h2>
          <pre><code>{`import RiverMap from 'cobogo/components/decorative/RiverMap';

<div style="position: relative;">
  <RiverMap color="var(--vermelho)" opacity={0.3} />
  <!-- Content over background -->
</div>`}</code></pre>
        </header>
      </article>
    </section>
  </main>

  <footer data-region="site-footer">
    <p><small data-kicker>COBOGÓ Design System — Componentes Decorativos</small></p>
  </footer>
</BaseLayout>

<style is:global>
  body:has([data-region="tile-sidebar"]) { padding-left: 80px; }
  @media (max-width: 600px) { body:has([data-region="tile-sidebar"]) { padding-left: 0; } }
</style>

<style>
  main { max-width: 1240px; margin: 0 auto; padding: 0 2rem; }
  main > [data-page-header] { padding: 6rem 0; border-bottom: 1px solid var(--border); margin-bottom: 0; }
  main > [data-page-header] hgroup h1 {
    font-family: var(--font-display-alt);
    font-size: 5rem;
    line-height: 0.9;
    margin: 0 0 2rem;
  }
  main > [data-page-header] hgroup p {
    font-size: 1.25rem;
    color: var(--fg-muted);
    max-width: 600px;
  }

  [data-decorative-grid] {
    padding: 6rem 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
    gap: 4rem;
  }
  [data-decorative-grid] article {
    border: 1px solid var(--border);
    border-radius: var(--r-soft);
    overflow: hidden;
    padding: 0;
    box-shadow: none;
    background: var(--papel-00);
  }
  [data-decorative-grid] article[data-span="full"] { grid-column: 1 / -1; }
  [data-decorative-grid] article > figure {
    margin: 0;
    padding: 4rem 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--border);
    background: var(--papel-00);
  }
  [data-decorative-grid] article > figure[data-bg="sunken"] { background: var(--bg-sunken); padding: 2rem; }
  [data-decorative-grid] article > figure[data-gap="lg"] { gap: 4rem; }
  [data-decorative-grid] article > figure[data-pad-top] { padding-top: 4rem; }
  [data-decorative-grid] article > figure[data-stage="foliage"] {
    min-height: 300px;
    position: relative;
    overflow: hidden;
    background: var(--bg-sunken);
  }
  [data-decorative-grid] article > figure[data-stage="rivermap"] {
    min-height: 300px;
    position: relative;
    overflow: hidden;
    background: var(--bg-raised);
  }
  [data-decorative-grid] article > figure[data-stage="rivermap"] h3 {
    position: relative;
    z-index: 1;
    padding: 2rem;
    margin: 0;
    font-family: var(--font-display);
    font-size: 2rem;
  }
  [data-decorative-grid] article > header {
    padding: 2rem;
    background: var(--bg-sunken);
    border: 0;
  }
  [data-decorative-grid] article > header h2 {
    font-size: 1.5rem;
    margin: 0 0 1rem;
  }
  [data-decorative-grid] pre {
    background: var(--concreto-90);
    color: var(--papel-10);
    padding: 1rem;
    border-radius: 4px;
    font-size: 0.85rem;
    overflow-x: auto;
    margin: 0;
  }

  [data-region="site-footer"] {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }

  @media (max-width: 768px) {
    main > [data-page-header] hgroup h1 { font-size: clamp(3rem, 8vw, 5rem); }
    [data-decorative-grid] { grid-template-columns: 1fr; }
  }
</style>
