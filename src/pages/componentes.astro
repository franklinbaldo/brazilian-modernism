---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ornaments from '../components/Ornaments.astro';
import ProfileCard from '../components/ProfileCard.svelte';
import DataTable from '../components/DataTable.svelte';
import SearchBar from '../components/SearchBar.svelte';
import Button from '../components/Button.svelte';
import Badge from '../components/Badge.svelte';
import TextInput from '../components/TextInput.svelte';
import MultiSelect from '../components/MultiSelect.svelte';
import DatePicker from '../components/DatePicker.svelte';
import TimePicker from '../components/TimePicker.svelte';
import Switch from '../components/Switch.svelte';
import Checkbox from '../components/Checkbox.svelte';
import Radio from '../components/Radio.svelte';
import Alert from '../components/Alert.svelte';
import Notification from '../components/Notification.svelte';
import Timeline from '../components/Timeline.svelte';

const tableHeaders = [
  { key: 'id', label: 'ID' },
  { key: 'item', label: 'Item' },
  { key: 'valor', label: 'Status' }
];

const tableData = [
  { id: '01', item: 'Brasília', valor: 'Ativo' },
  { id: '02', item: 'Pampulha', valor: 'Pendente' }
];

const mockOptions = [
  { value: 'br', label: 'Brasil' },
  { value: 'ar', label: 'Argentina' },
  { value: 'uy', label: 'Uruguai' }
];
---

<BaseLayout title="Vitrine de Componentes | COBOGÓ">
  <div class="app-wrapper">
    <aside class="tile-sidebar">
      <div class="sidebar-tiles pattern-cobogo-circular"></div>
    </aside>

    <main class="main-content">
      <nav class="container site-nav">
        <div class="nav-brand font-logo">COBOGÓ</div>
        <div class="nav-links">
          <a href="/cobogo/">Home</a>
          <a href="/cobogo/docs/getting-started/">Documentação</a>
          <a href="/cobogo/componentes/" class="active">Vitrine</a>
          <a href="/cobogo/patterns/">Patterns</a>
          <a href="/cobogo/composition/">Composition</a>
        </div>
      </nav>

      <header class="container page-header">
        <div class="kicker kicker--vermelho">Biblioteca Atômica</div>
        <h1 class="display-serif">Vitrine Curva<br/>& Concreto</h1>
        <p class="lede">
          Uma visualização rápida de todos os componentes criados pelo agente <strong>Brad Frost</strong>, 
          seguindo a arquitetura de átomos, moléculas e organismos.
        </p>
      </header>

      <Ornaments type="waveline" height={24} color="var(--concreto-30)" className="container" />

      <!-- ÁTOMOS -->
      <section class="container showcase-section">
        <h2 class="showcase-title">01. Átomos</h2>
        <p class="showcase-desc">As menores unidades funcionais. Baseadas em geometria pura.</p>
        
        <div class="showcase-grid">
          <div class="showcase-card">
            <h3>Botões</h3>
            <div class="flex-stack">
              <Button client:load>Primário</Button>
              <Button client:load variant="secondary">Secundário</Button>
            </div>
          </div>
          
          <div class="showcase-card">
            <h3>Badges</h3>
            <div class="flex-row">
              <Badge client:load variant="verde">Sucesso</Badge>
              <Badge client:load variant="azul">Info</Badge>
              <Badge client:load variant="vermelho">Erro</Badge>
            </div>
          </div>

          <div class="showcase-card">
            <h3>Toggles</h3>
            <div class="flex-row" style="align-items: center; gap: 2rem;">
              <Switch client:load label="Switch" />
              <Checkbox client:load label="Checkbox" checked />
              <Radio client:load label="Radio" checked />
            </div>
          </div>
          
          <div class="showcase-card">
            <h3>Inputs de Texto</h3>
            <TextInput client:load placeholder="Ex: Oscar Niemeyer" label="Nome Completo" />
          </div>
        </div>
      </section>

      <!-- MOLÉCULAS -->
      <section class="container showcase-section">
        <h2 class="showcase-title">02. Moléculas</h2>
        <p class="showcase-desc">União de átomos para formar componentes mais complexos.</p>
        
        <div class="showcase-grid">
          <div class="showcase-card">
            <h3>Seleção Múltipla</h3>
            <MultiSelect 
              client:load 
              options={mockOptions} 
              placeholder="Escolha os países..." 
              value={['br']}
            />
          </div>

          <div class="showcase-card">
            <h3>Seleção de Data</h3>
            <DatePicker client:load label="Data de Fundação" />
          </div>

          <div class="showcase-card">
            <h3>Seleção de Horário</h3>
            <TimePicker client:load label="Horário de Início" />
          </div>

          <div class="showcase-card">
            <h3>Alertas</h3>
            <Alert client:load title="Atenção" intent="warning">
              Esta ação não pode ser desfeita após o salvamento.
            </Alert>
          </div>
        </div>
      </section>

      <!-- ORGANISMOS -->
      <section class="container showcase-section">
        <h2 class="showcase-title">03. Organismos</h2>
        <p class="showcase-desc">Componentes robustos e prontos para aplicação em produtos reais.</p>
        
        <div class="showcase-grid showcase-grid--wide">
          <div class="showcase-card">
            <h3>Tabelas de Dados</h3>
            <DataTable 
              client:load 
              headers={tableHeaders} 
              data={tableData} 
              variant="striped"
            />
          </div>

          <div class="showcase-card">
            <h3>Barra de Busca Inteligente</h3>
            <SearchBar 
              client:load 
              placeholder="Pesquisar no sistema..." 
            />
          </div>
        </div>

        <div class="showcase-grid" style="margin-top: 2rem;">
          <div class="showcase-card">
            <h3>Cartão de Perfil</h3>
            <ProfileCard 
              client:load
              name="Lina Bo Bardi"
              role="Arquiteta e Designer"
              tags={['Vidro', 'Social']}
            />
          </div>

          <div class="showcase-card">
            <h3>Notificações</h3>
            <div style="background: var(--bg-sunken); padding: 1rem; border-radius: var(--r-soft);">
              <Notification client:load intent="tip">
                Seu projeto foi salvo com sucesso no servidor.
              </Notification>
            </div>
          </div>
        </div>
      </section>

      <footer class="container site-footer" style="padding: 4rem 0; border-top: 1px solid var(--border);">
        <p class="tracked-caps">COBOGÓ Design System — v0.1.0</p>
        <a href="/cobogo/docs/getting-started/" class="link">Ver documentação técnica completa <span>→</span></a>
      </footer>
    </main>
  </div>
</BaseLayout>

<style>
  .showcase-section {
    padding: 6rem 0;
  }

  .showcase-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    color: var(--azul);
  }

  .showcase-desc {
    color: var(--fg-muted);
    margin-bottom: 3rem;
    font-size: 1.125rem;
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  .showcase-grid--wide {
    grid-template-columns: 1fr;
  }

  .showcase-card {
    background: var(--papel-00);
    padding: 2.5rem;
    border: 1px solid var(--border);
    border-radius: var(--r-soft);
    box-shadow: var(--shadow-1);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .showcase-card h3 {
    font-size: var(--t-small);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--concreto-60);
    margin-top: 0;
  }

  .flex-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .flex-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .display-serif {
    font-family: var(--font-display-alt);
    font-size: 5rem;
    line-height: 0.9;
    margin-bottom: 2rem;
  }

  .page-header {
    padding: 8rem 0 4rem;
  }

  .lede {
    font-size: 1.5rem;
    color: var(--fg-muted);
    max-width: 650px;
    line-height: 1.4;
  }

  .active {
    font-weight: 800;
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .display-serif {
      font-size: 3.5rem;
    }
    .showcase-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
