---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.svelte';
import Badge from '../components/Badge.svelte';
---

<BaseLayout title="Faithful Evolution | COBOGÓ">
  <aside aria-hidden="true" data-pattern="cobogo-hexagonal" data-region="tile-sidebar">
    <nav data-marginalia aria-label="Marginalia">
      <ol>
        <li><a href="#processo" aria-current="step" title="Processo"><span aria-hidden="true"></span></a></li>
        <li><a href="#documentos" title="Documentos"><span aria-hidden="true"></span></a></li>
        <li><a href="#assinaturas" title="Assinaturas"><span aria-hidden="true"></span></a></li>
      </ol>
    </nav>
  </aside>

  <header data-region="site-header" data-official>
    <div data-header-inner>
      <span aria-hidden="true" data-modernist-seal></span>
      <hgroup>
        <p><small data-kicker>República Federativa do Brasil</small></p>
        <h1>Tribunal de Justiça</h1>
      </hgroup>
      <Badge intent="verde">Protocolo Ativo</Badge>
    </div>
  </header>

  <main>
    <section data-evolution>
      <article id="processo">
        <hgroup>
          <h2>Physical Buttons</h2>
          <p>Using hard shadows instead of floating effects to respect the "Geometric" and "Objective" principles.</p>
        </hgroup>
        <p>
          <Button intent="primary">Confirmar Protocolo</Button>
          <Button intent="outline">Voltar ao Acervo</Button>
        </p>
      </article>

      <article id="documentos">
        <hgroup>
          <h2>Editorial Marginalia</h2>
          <p>Important context belongs in the gutters, following the "Organized" principle.</p>
        </hgroup>
        <div data-marginalia-block>
          <p>Este documento eletrônico é uma representação digital de um processo público de interesse cívico. A integridade é garantida por criptografia assimétrica conforme os padrões estabelecidos pelo manifesto Cobogó.</p>
          <aside>
            <small data-kicker>Meta</small>
            <p>ID: 402/2024<br />HASH: 8F2A...91</p>
          </aside>
        </div>
      </article>

      <article id="assinaturas">
        <hgroup>
          <h2>Living Cobogós</h2>
          <p>Interplay of light and shadow through interactivity.</p>
        </hgroup>
        <figure data-pattern="cobogo-circular" data-pattern-playground>
          <span data-light-source aria-hidden="true"></span>
        </figure>
      </article>
    </section>
  </main>

  <footer data-region="site-footer">
    <p><small data-kicker>Evolução do Design System — Audit Visual 2026</small></p>
  </footer>
</BaseLayout>

<style is:global>
  body:has([data-region="tile-sidebar"]) { padding-left: 80px; }
  @media (max-width: 600px) { body:has([data-region="tile-sidebar"]) { padding-left: 0; } }
</style>

<style>
  [data-marginalia] {
    position: relative;
    z-index: 2;
    padding-top: 10rem;
  }
  [data-marginalia] ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }
  [data-marginalia] a span {
    width: 12px;
    height: 12px;
    display: block;
    border: 2px solid white;
    border-radius: 50%;
  }
  [data-marginalia] a[aria-current="step"] span {
    background: white;
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
  }

  header[data-official] {
    background: var(--papel-00);
    border-bottom: 2px solid var(--concreto-90);
    padding: 2rem;
  }
  [data-header-inner] {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  [data-modernist-seal] {
    width: 64px;
    height: 64px;
    background: var(--vermelho);
    clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);
    border: 3px solid var(--concreto-90);
    display: block;
    flex-shrink: 0;
  }
  header[data-official] hgroup { flex: 1; }
  header[data-official] hgroup h1 {
    font-family: var(--font-display-alt);
    font-size: 2.5rem;
    margin: 0;
  }

  main { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  [data-evolution] {
    padding: 6rem 0;
    display: flex;
    flex-direction: column;
    gap: 8rem;
  }
  [data-evolution] > article {
    background: transparent;
    border: 0;
    box-shadow: none;
    padding: 0;
  }
  [data-evolution] > article hgroup h2 { font-family: var(--font-display); font-size: 2rem; margin: 0 0 0.5rem; }
  [data-evolution] > article hgroup p { color: var(--fg-muted); margin: 0 0 2rem; }
  [data-evolution] > article > p { display: flex; gap: 2rem; flex-wrap: wrap; }

  [data-marginalia-block] {
    display: grid;
    grid-template-columns: 1fr 160px;
    gap: 4rem;
    padding: 2rem;
    background: var(--papel-20);
    border-left: 4px solid var(--ocre);
  }
  [data-marginalia-block] > aside {
    font-size: 0.75rem;
    color: var(--fg-muted);
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    background: transparent;
  }

  [data-pattern-playground] {
    height: 300px;
    border: 2px solid var(--concreto-90);
    position: relative;
    overflow: hidden;
    background-color: var(--papel-00);
    background-image: url('/cobogo/patterns/cobogo-circular.svg');
    background-size: 80px 80px;
    margin: 0;
  }
  [data-light-source] {
    position: absolute;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.8) 0%, transparent 70%);
    pointer-events: none;
    transform: translate(-50%, -50%);
    mix-blend-mode: overlay;
  }

  [data-region="site-footer"] {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    color: var(--fg-muted);
  }
</style>

<script>
  const playground = document.querySelector<HTMLElement>('[data-pattern-playground]');
  const light = document.querySelector<HTMLElement>('[data-light-source]');
  if (playground && light) {
    playground.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = playground.getBoundingClientRect();
      light.style.left = `${e.clientX - rect.left}px`;
      light.style.top = `${e.clientY - rect.top}px`;
    });
  }
</script>
