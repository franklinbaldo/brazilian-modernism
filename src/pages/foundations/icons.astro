---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrIcon from '../../components/BrIcon.svelte';
---

<BaseLayout title="Icons | COBOGÓ">
  <div class="wrap" style="padding: 4rem 0;">
    <h1>Iconografia brasileira</h1>
    <p class="lede">Biblioteca de ícones cobogó organizados em 4 estilos: geometric, civic, folk e cotidiano.</p>

    <h2>Geometric (14)</h2>
    <p>currentColor — tinta via CSS. Use pra patterns e ícones funcionais.</p>
    <div class="icon-grid" style="color: var(--azul);">
      <div class="icon-cell"><BrIcon name="azulejo-modernista" size={80} /><span class="icon-cell-name">azulejo-modernista</span></div>
      <div class="icon-cell"><BrIcon name="bulcao-amarelo" size={80} /><span class="icon-cell-name">bulcao-amarelo</span></div>
      <div class="icon-cell"><BrIcon name="bulcao-azul" size={80} /><span class="icon-cell-name">bulcao-azul</span></div>
      <div class="icon-cell"><BrIcon name="bulcao-verde" size={80} /><span class="icon-cell-name">bulcao-verde</span></div>
      <div class="icon-cell"><BrIcon name="bulcao-vermelho" size={80} /><span class="icon-cell-name">bulcao-vermelho</span></div>
      <div class="icon-cell"><BrIcon name="burle-marx" size={80} /><span class="icon-cell-name">burle-marx</span></div>
      <div class="icon-cell"><BrIcon name="calcada-ipanema" size={80} /><span class="icon-cell-name">calcada-ipanema</span></div>
      <div class="icon-cell"><BrIcon name="calcada-onda" size={80} /><span class="icon-cell-name">calcada-onda</span></div>
      <div class="icon-cell"><BrIcon name="cestaria" size={80} /><span class="icon-cell-name">cestaria</span></div>
      <div class="icon-cell"><BrIcon name="chita" size={80} /><span class="icon-cell-name">chita</span></div>
      <div class="icon-cell"><BrIcon name="concretismo" size={80} /><span class="icon-cell-name">concretismo</span></div>
      <div class="icon-cell"><BrIcon name="marajoara" size={80} /><span class="icon-cell-name">marajoara</span></div>
      <div class="icon-cell"><BrIcon name="pedra-portuguesa" size={80} /><span class="icon-cell-name">pedra-portuguesa</span></div>
      <div class="icon-cell"><BrIcon name="rosacea-barroca" size={80} /><span class="icon-cell-name">rosacea-barroca</span></div>
    </div>

    <h2>Civic (9)</h2>
    <p>Silhueta com paleta fixa quando icônica. Use pra ornamentos figurativos cívicos.</p>
    <div class="icon-grid">
      <div class="icon-cell"><BrIcon name="barco-ribeirinho" size={80} /><span class="icon-cell-name">barco-ribeirinho</span></div>
      <div class="icon-cell"><BrIcon name="bonde" size={80} /><span class="icon-cell-name">bonde</span></div>
      <div class="icon-cell"><BrIcon name="caixa-dagua" size={80} /><span class="icon-cell-name">caixa-dagua</span></div>
      <div class="icon-cell"><BrIcon name="coreto" size={80} /><span class="icon-cell-name">coreto</span></div>
      <div class="icon-cell"><BrIcon name="fachada-art-deco" size={80} /><span class="icon-cell-name">fachada-art-deco</span></div>
      <div class="icon-cell"><BrIcon name="guardasol" size={80} /><span class="icon-cell-name">guardasol</span></div>
      <div class="icon-cell"><BrIcon name="jangada" size={80} /><span class="icon-cell-name">jangada</span></div>
      <div class="icon-cell"><BrIcon name="orelhao" size={80} /><span class="icon-cell-name">orelhao</span></div>
      <div class="icon-cell"><BrIcon name="palafita" size={80} /><span class="icon-cell-name">palafita</span></div>
    </div>

    <h2>Folk (8)</h2>
    <p>Linha xilográfica. Use com peso histórico, em contextos folk pontuais.</p>
    <div class="icon-grid">
      <div class="icon-cell"><BrIcon name="bandeirinhas" size={80} /><span class="icon-cell-name">bandeirinhas</span></div>
      <div class="icon-cell"><BrIcon name="berimbau" size={80} /><span class="icon-cell-name">berimbau</span></div>
      <div class="icon-cell"><BrIcon name="carranca" size={80} /><span class="icon-cell-name">carranca</span></div>
      <div class="icon-cell"><BrIcon name="cordel-ornament" size={80} /><span class="icon-cell-name">cordel-ornament</span></div>
      <div class="icon-cell"><BrIcon name="estandarte-maracatu" size={80} /><span class="icon-cell-name">estandarte-maracatu</span></div>
      <div class="icon-cell"><BrIcon name="fitinhas-bonfim" size={80} /><span class="icon-cell-name">fitinhas-bonfim</span></div>
      <div class="icon-cell"><BrIcon name="pipa" size={80} /><span class="icon-cell-name">pipa</span></div>
      <div class="icon-cell"><BrIcon name="sanfona" size={80} /><span class="icon-cell-name">sanfona</span></div>
    </div>

    <h2>Cotidiano (18)</h2>
    <p>"Grita Brasil" imediato — doméstico/comercial/burocrático.</p>
    <div class="icon-grid">
      <div class="icon-cell"><BrIcon name="botijao-gas" size={80} /><span class="icon-cell-name">botijao-gas</span></div>
      <div class="icon-cell"><BrIcon name="cadeira-longarina" size={80} /><span class="icon-cell-name">cadeira-longarina</span></div>
      <div class="icon-cell"><BrIcon name="cadeira-plastico" size={80} /><span class="icon-cell-name">cadeira-plastico</span></div>
      <div class="icon-cell"><BrIcon name="canga" size={80} /><span class="icon-cell-name">canga</span></div>
      <div class="icon-cell"><BrIcon name="carimbo-protocolo" size={80} /><span class="icon-cell-name">carimbo-protocolo</span></div>
      <div class="icon-cell"><BrIcon name="chuveiro-eletrico" size={80} /><span class="icon-cell-name">chuveiro-eletrico</span></div>
      <div class="icon-cell"><BrIcon name="copo-americano" size={80} /><span class="icon-cell-name">copo-americano</span></div>
      <div class="icon-cell"><BrIcon name="estufa-salgado" size={80} /><span class="icon-cell-name">estufa-salgado</span></div>
      <div class="icon-cell"><BrIcon name="faixa-caminhao" size={80} /><span class="icon-cell-name">faixa-caminhao</span></div>
      <div class="icon-cell"><BrIcon name="filtro-barro" size={80} /><span class="icon-cell-name">filtro-barro</span></div>
      <div class="icon-cell"><BrIcon name="guardanapeira" size={80} /><span class="icon-cell-name">guardanapeira</span></div>
      <div class="icon-cell"><BrIcon name="kombi" size={80} /><span class="icon-cell-name">kombi</span></div>
      <div class="icon-cell"><BrIcon name="letreiro-pintado" size={80} /><span class="icon-cell-name">letreiro-pintado</span></div>
      <div class="icon-cell"><BrIcon name="mesa-plastico" size={80} /><span class="icon-cell-name">mesa-plastico</span></div>
      <div class="icon-cell"><BrIcon name="pasta-az" size={80} /><span class="icon-cell-name">pasta-az</span></div>
      <div class="icon-cell"><BrIcon name="placa-br" size={80} /><span class="icon-cell-name">placa-br</span></div>
      <div class="icon-cell"><BrIcon name="pote-sorvete" size={80} /><span class="icon-cell-name">pote-sorvete</span></div>
      <div class="icon-cell"><BrIcon name="sacola-feira" size={80} /><span class="icon-cell-name">sacola-feira</span></div>
    </div>
  </div>
</BaseLayout>

<style>
  .icon-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 2rem; padding: 2rem 0; }
  .icon-cell { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; padding: 1.5rem; border: 1px solid var(--border); border-radius: var(--r-soft); background: var(--bg-raised); }
  .icon-cell-name { font-size: var(--t-small); color: var(--fg-muted); font-family: var(--font-sans); }

  @media (max-width: 480px) {
    .icon-grid {
      gap: 1.5rem;
    }
    h2 {
      font-size: clamp(1.5rem, 6vw, var(--t-h2));
    }
  }
</style>
