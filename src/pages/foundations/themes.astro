---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.svelte';
import Button from '../../components/Button.svelte';
---

<BaseLayout title="Themes | Foundations | COBOGÓ">
  <div class="wrap">
    <div style="padding: 4rem 0;">
      <a href="/cobogo/foundations" style="font-family: var(--font-sans); font-size: 0.875rem; font-weight: 700; color: var(--fg-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 2rem;">
        <span>←</span> Voltar para Foundations
      </a>
      <h1 class="kicker">Foundations</h1>
      <h2 class="hero__title">Theme Variants & Textures</h2>
      <p class="hero__lead">Expressões temáticas e texturas decorativas do cotidiano brasileiro.</p>
    </div>

    <section style="margin-bottom: 6rem;">
      <h3 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 2rem;">Light vs Dark</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 3rem;">

        <div class="light-mode-preview" style="padding: 2rem; background: var(--bg-sunken); border-radius: var(--r-soft); border: 1px solid var(--border);">
          <div style="margin-bottom: 1rem;">
            <strong style="color: var(--fg-heading); font-family: var(--font-sans);">Light Mode (Forçado)</strong>
          </div>
          <Card title="Card no Light Mode">
            Este card usa a paleta de cores normal do light mode (bg claro, fg escuro).
            <div style="margin-top: 1rem;">
              <Button variant="azul">Ação principal</Button>
            </div>
          </Card>
        </div>

        <div class="dark-mode dark-mode-preview" style="padding: 2rem; background: var(--bg-sunken); border-radius: var(--r-soft); border: 1px solid var(--border);">
          <div style="margin-bottom: 1rem;">
            <strong style="color: var(--fg-heading); font-family: var(--font-sans);">Dark Mode (Forçado)</strong>
          </div>
          <Card title="Card no Dark Mode">
            Este card usa a paleta de cores do dark mode (bg escuro, fg claro).
            <div style="margin-top: 1rem;">
              <Button variant="azul">Ação principal</Button>
            </div>
          </Card>
        </div>

      </div>
    </section>

    <section style="margin-bottom: 6rem;">
      <h3 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 2rem;">Themes</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 3rem;">

        <div>
          <div class="theme-lambe" style="margin-bottom: 1rem;">
            A CIDADE É NOSSA
          </div>
          <code style="font-size: 0.875rem; color: var(--fg-muted);">.theme-lambe</code>
        </div>

        <div>
          <div style="padding: 2rem; background: var(--papel-10); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
            <div class="theme-carimbo">
              RECEBIDO 30/04/2026
            </div>
          </div>
          <code style="font-size: 0.875rem; color: var(--fg-muted);">.theme-carimbo</code>
        </div>

        <div>
          <div class="theme-boteco" style="margin-bottom: 1rem; text-align: center; font-size: 2rem;">
            BOTECO DA ESQUINA — CHOPP GELADO
          </div>
          <code style="font-size: 0.875rem; color: var(--fg-muted);">.theme-boteco</code>
        </div>

        <div>
          <div class="theme-faixa-caminhao" style="margin-bottom: 1rem;">
            DEUS NO COMANDO SEMPRE
          </div>
          <code style="font-size: 0.875rem; color: var(--fg-muted);">.theme-faixa-caminhao</code>
        </div>

      </div>
    </section>

    <section style="margin-bottom: 6rem;">
      <h3 style="font-family: var(--font-display); font-size: 1.5rem; margin-bottom: 2rem;">Textures</h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 3rem;">

        <div>
          <div class="texture-papel-velho" style="height: 200px; background: var(--bg-raised); border: 1px solid var(--border); border-radius: var(--r-soft); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
            <span style="font-family: var(--font-sans); font-weight: 700; color: var(--fg-muted);">Papel Velho</span>
          </div>
          <code style="font-size: 0.875rem; color: var(--fg-muted);">.texture-papel-velho</code>
        </div>

        <div>
          <div class="texture-concreto" style="height: 200px; background: var(--bg-raised); border: 1px solid var(--border); border-radius: var(--r-soft); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; overflow: hidden;">
            <span style="font-family: var(--font-sans); font-weight: 700; color: var(--fg-muted); z-index: 1;">Concreto</span>
          </div>
          <code style="font-size: 0.875rem; color: var(--fg-muted);">.texture-concreto</code>
        </div>

        <div>
          <div class="texture-palha" style="height: 200px; background-color: var(--bg-raised); border: 1px solid var(--border); border-radius: var(--r-soft); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
            <span style="font-family: var(--font-sans); font-weight: 700; color: var(--fg-muted); background: var(--papel-00); padding: 0.25rem 0.5rem; border-radius: var(--r-1);">Palha</span>
          </div>
          <code style="font-size: 0.875rem; color: var(--fg-muted);">.texture-palha</code>
        </div>

      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .light-mode-preview {
    /* Força os tokens do light mode */
    --papel-00: #FBF8F1;
    --papel-10: #F5F1E8;
    --papel-20: #EDE7D8;
    --papel-30: #DCD4BE;
    --concreto-40: #B8B0A0;
    --concreto-60: #6B6455;
    --concreto-80: #2E2A24;
    --concreto-90: #1A1814;
    --bg: var(--papel-10);
    --bg-raised: var(--papel-00);
    --bg-sunken: var(--papel-20);
    --fg: var(--concreto-80);
    --fg-muted: var(--concreto-60);
    --fg-heading: var(--concreto-90);
    --border: var(--papel-30);
    --border-strong: var(--concreto-80);
  }
</style>
