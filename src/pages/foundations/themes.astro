---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.svelte';
import Button from '../../components/Button.svelte';
---

<BaseLayout title="Themes | Foundations | COBOGÓ">
  <main>
    <header data-page-header>
      <p><a href="/cobogo/foundations" rel="up">← Voltar para Foundations</a></p>
      <hgroup>
        <p><small data-kicker>Foundations</small></p>
        <h1>Theme Variants &amp; Textures</h1>
        <p>Expressões temáticas e texturas decorativas do cotidiano brasileiro.</p>
      </hgroup>
    </header>

    <section data-themes>
      <h3>Light vs Dark</h3>
      <div data-theme-grid>
        <article data-theme="light">
          <header><strong>Light Mode (Forçado)</strong></header>
          <Card>
            <h4>Card no Light Mode</h4>
            <p>Este card usa a paleta de cores normal do light mode (bg claro, fg escuro).</p>
            <p><Button intent="primary">Ação principal</Button></p>
          </Card>
        </article>
        <article data-theme="dark">
          <header><strong>Dark Mode (Forçado)</strong></header>
          <Card>
            <h4>Card no Dark Mode</h4>
            <p>Este card usa a paleta de cores do dark mode (bg escuro, fg claro).</p>
            <p><Button intent="primary">Ação principal</Button></p>
          </Card>
        </article>
      </div>
    </section>

    <section data-themes>
      <h3>Themes</h3>
      <div data-theme-variants>
        <figure>
          <div data-theme-tag="lambe">A CIDADE É NOSSA</div>
          <figcaption><code>[data-theme-tag="lambe"]</code></figcaption>
        </figure>
        <figure>
          <div data-theme-stage>
            <div data-theme-tag="carimbo">RECEBIDO 30/04/2026</div>
          </div>
          <figcaption><code>[data-theme-tag="carimbo"]</code></figcaption>
        </figure>
        <figure>
          <div data-theme-tag="boteco">BOTECO DA ESQUINA — CHOPP GELADO</div>
          <figcaption><code>[data-theme-tag="boteco"]</code></figcaption>
        </figure>
        <figure>
          <div data-theme-tag="faixa-caminhao">DEUS NO COMANDO SEMPRE</div>
          <figcaption><code>[data-theme-tag="faixa-caminhao"]</code></figcaption>
        </figure>
      </div>
    </section>

    <section data-themes>
      <h3>Textures</h3>
      <div data-textures>
        <figure>
          <div data-texture="papel-velho">
            <span>Papel Velho</span>
          </div>
          <figcaption><code>[data-texture="papel-velho"]</code></figcaption>
        </figure>
        <figure>
          <div data-texture="concreto">
            <span>Concreto</span>
          </div>
          <figcaption><code>[data-texture="concreto"]</code></figcaption>
        </figure>
        <figure>
          <div data-texture="palha">
            <span>Palha</span>
          </div>
          <figcaption><code>[data-texture="palha"]</code></figcaption>
        </figure>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  main { max-width: 1240px; margin: 0 auto; padding: 4rem 2rem; }
  main > [data-page-header] { margin-bottom: 3rem; max-width: 720px; }
  main > [data-page-header] > p:first-child a {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--fg-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  main > [data-page-header] hgroup h1 {
    font-size: var(--t-h1);
    margin: 1rem 0 1.5rem;
    line-height: var(--lh-tight);
  }
  main > [data-page-header] hgroup p:last-child {
    font-size: var(--t-lede);
    color: var(--fg-muted);
  }

  [data-themes] { margin-bottom: 6rem; }
  [data-themes] h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }
  [data-theme-grid], [data-theme-variants], [data-textures] {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  [data-theme-grid] article {
    padding: 2rem;
    background: var(--bg-sunken);
    border: 1px solid var(--border);
    border-radius: var(--r-soft);
    box-shadow: none;
  }
  [data-theme-grid] article > header { margin-bottom: 1rem; padding: 0; border: 0; background: transparent; }
  [data-theme-grid] article[data-theme="light"] {
    --papel-00: #FBF8F1; --papel-10: #F5F1E8; --papel-20: #EDE7D8; --papel-30: #DCD4BE;
    --concreto-40: #B8B0A0; --concreto-60: #6B6455; --concreto-80: #2E2A24; --concreto-90: #1A1814;
    --bg: var(--papel-10); --bg-raised: var(--papel-00); --bg-sunken: var(--papel-20);
    --fg: var(--concreto-80); --fg-muted: var(--concreto-60); --fg-heading: var(--concreto-90);
    --border: var(--papel-30);
  }

  [data-theme-variants] figure { margin: 0; display: flex; flex-direction: column; gap: 1rem; }
  [data-theme-variants] figcaption code { font-size: 0.875rem; color: var(--fg-muted); }
  [data-theme-stage] {
    padding: 2rem;
    background: var(--papel-10);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  [data-textures] figure { margin: 0; display: flex; flex-direction: column; gap: 1rem; }
  [data-textures] figcaption code { font-size: 0.875rem; color: var(--fg-muted); }
  [data-texture] {
    height: 200px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--r-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  [data-texture] > span {
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--fg-muted);
  }
  [data-texture="palha"] > span {
    background: var(--papel-00);
    padding: 0.25rem 0.5rem;
    border-radius: var(--r-1);
  }
</style>
