---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Typography | Foundations | COBOGÓ">
  <div class="wrap">
    <div style="padding: 4rem 0;">
      <h1 class="kicker">Foundations</h1>
      <h2 class="hero__title">Typography</h2>
      <p class="hero__lead">Display fonts brasileiros.</p>
    </div>

    <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-bottom: 4rem;">
      <article style="background: var(--bg-raised); padding: 2rem; border: 1px solid var(--border); border-radius: var(--r-soft);">
        <h3 style="font-family: var(--font-display); font-size: 1rem; color: var(--fg-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 2rem;">Letreiro</h3>
        <p style="font-family: var(--font-letreiro); font-size: var(--t-h2); line-height: 1.1; margin-bottom: 1rem; color: var(--fg-heading);">Padaria do Seu Zé · Pão Quente Toda Hora</p>
        <p style="font-family: var(--font-letreiro); font-size: var(--t-body); line-height: 1.4; margin-bottom: 1rem;">Padaria do Seu Zé · Pão Quente Toda Hora</p>
        <p style="font-family: var(--font-letreiro); font-size: var(--t-small); line-height: 1.4; color: var(--fg-muted);">Padaria do Seu Zé · Pão Quente Toda Hora</p>
        <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border); font-family: var(--font-sans); font-size: 0.75rem; color: var(--fg-muted);">
          Caveat / Handpaint padaria/comércio
        </div>
      </article>

      <article style="background: var(--bg-raised); padding: 2rem; border: 1px solid var(--border); border-radius: var(--r-soft);">
        <h3 style="font-family: var(--font-display); font-size: 1rem; color: var(--fg-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 2rem;">Jornal</h3>
        <p style="font-family: var(--font-jornal); font-size: var(--t-h2); line-height: 1.1; margin-bottom: 1rem; color: var(--fg-heading);">O BRASIL — A DEMOCRACIA EM CONSTRUÇÃO</p>
        <p style="font-family: var(--font-jornal); font-size: var(--t-body); line-height: 1.4; margin-bottom: 1rem;">O BRASIL — A DEMOCRACIA EM CONSTRUÇÃO</p>
        <p style="font-family: var(--font-jornal); font-size: var(--t-small); line-height: 1.4; color: var(--fg-muted);">O BRASIL — A DEMOCRACIA EM CONSTRUÇÃO</p>
        <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border); font-family: var(--font-sans); font-size: 0.75rem; color: var(--fg-muted);">
          PT Serif Caption / Manchete editorial densa
        </div>
      </article>

      <article style="background: var(--bg-raised); padding: 2rem; border: 1px solid var(--border); border-radius: var(--r-soft);">
        <h3 style="font-family: var(--font-display); font-size: 1rem; color: var(--fg-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 2rem;">Cordel</h3>
        <p style="font-family: var(--font-cordel); font-size: var(--t-h2); line-height: 1.1; margin-bottom: 1rem; color: var(--fg-heading);">COBOGÓ É RESISTÊNCIA</p>
        <p style="font-family: var(--font-cordel); font-size: var(--t-body); line-height: 1.4; margin-bottom: 1rem;">COBOGÓ É RESISTÊNCIA</p>
        <p style="font-family: var(--font-cordel); font-size: var(--t-small); line-height: 1.4; color: var(--fg-muted);">COBOGÓ É RESISTÊNCIA</p>
        <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--border); font-family: var(--font-sans); font-size: 0.75rem; color: var(--fg-muted);">
          Bevan / Display chunky tipo woodcut
        </div>
      </article>
    </section>
  </div>
</BaseLayout>
