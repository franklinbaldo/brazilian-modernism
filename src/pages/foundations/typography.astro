---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Typography | Foundations | COBOGÓ">
  <main>
    <header data-page-header>
      <hgroup>
        <p><small data-kicker>Foundations</small></p>
        <h1>Typography</h1>
        <p>Display fonts brasileiros.</p>
      </hgroup>
    </header>

    <section data-typography-grid>
      <article data-typeface="letreiro">
        <header><h3>Letreiro</h3></header>
        <p style="font-size:var(--t-h2)">Padaria do Seu Zé · Pão Quente Toda Hora</p>
        <p>Padaria do Seu Zé · Pão Quente Toda Hora</p>
        <p style="font-size:var(--t-small)">Padaria do Seu Zé · Pão Quente Toda Hora</p>
        <footer>Caveat / Handpaint padaria/comércio</footer>
      </article>

      <article data-typeface="jornal">
        <header><h3>Jornal</h3></header>
        <p style="font-size:var(--t-h2)">O BRASIL — A DEMOCRACIA EM CONSTRUÇÃO</p>
        <p>O BRASIL — A DEMOCRACIA EM CONSTRUÇÃO</p>
        <p style="font-size:var(--t-small)">O BRASIL — A DEMOCRACIA EM CONSTRUÇÃO</p>
        <footer>PT Serif Caption / Manchete editorial densa</footer>
      </article>

      <article data-typeface="cordel">
        <header><h3>Cordel</h3></header>
        <p style="font-size:var(--t-h2)">COBOGÓ É RESISTÊNCIA</p>
        <p>COBOGÓ É RESISTÊNCIA</p>
        <p style="font-size:var(--t-small)">COBOGÓ É RESISTÊNCIA</p>
        <footer>Bevan / Display chunky tipo woodcut</footer>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  main { max-width: 1240px; margin: 0 auto; padding: 4rem 2rem; }
  main > [data-page-header] { margin-bottom: 3rem; max-width: 720px; }
  main > [data-page-header] hgroup h1 {
    font-size: var(--t-h1);
    margin: 1rem 0 1.5rem;
    line-height: var(--lh-tight);
  }
  main > [data-page-header] hgroup p:last-child {
    font-size: var(--t-lede);
    color: var(--fg-muted);
  }

  [data-typography-grid] {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    padding: 0;
    border: 0;
  }
  [data-typography-grid] article {
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--r-soft);
    background: var(--bg-raised);
    box-shadow: none;
  }
  [data-typography-grid] header { padding: 0; border: 0; background: transparent; margin-bottom: 2rem; }
  [data-typography-grid] header h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }
  [data-typography-grid] article p { line-height: 1.4; margin-bottom: 1rem; }
  [data-typography-grid] article p:first-of-type { color: var(--fg-heading); line-height: 1.1; }
  [data-typography-grid] article p:last-of-type { color: var(--fg-muted); }
  [data-typography-grid] article > footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--fg-muted);
  }

  [data-typeface="letreiro"] p { font-family: var(--font-letreiro); }
  [data-typeface="jornal"]   p { font-family: var(--font-jornal); }
  [data-typeface="cordel"]   p { font-family: var(--font-cordel); }

  @media (max-width: 768px) {
    [data-typography-grid] { grid-template-columns: 1fr; }
    main > [data-page-header] hgroup h1 { font-size: clamp(2.5rem, 8vw, var(--t-h1)); }
    main > [data-page-header] hgroup p:last-child { font-size: clamp(1rem, 4vw, var(--t-lede)); }
  }
</style>
