---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Foundations | COBOGÓ">
  <main>
    <header data-page-header>
      <hgroup>
        <p><small data-kicker>Foundations</small></p>
        <h1>Fundações do COBOGÓ</h1>
        <p>Tokens, tipografia, ícones, themes e texturas brasileiras — a base da gramática visual do design system.</p>
      </hgroup>
    </header>

    <section data-foundations-grid>
      <article data-interactive>
        <a href="/cobogo/docs/foundations/tokens/">
          <h2>Tokens</h2>
          <p>Paleta papel/concreto + primárias saturadas, semânticos, escalas tipográficas, radius, shadows e motion.</p>
          <footer>Ver tokens →</footer>
        </a>
      </article>
      <article data-interactive>
        <a href="/cobogo/foundations/typography/">
          <h2>Typography</h2>
          <p>Archivo, Fraunces, Piazzolla, JetBrains Mono — mais display fonts brasileiros: Caveat (letreiro), PT Serif Caption (jornal), Bevan (cordel).</p>
          <footer>Ver typography →</footer>
        </a>
      </article>
      <article data-interactive>
        <a href="/cobogo/foundations/icons/">
          <h2>Icons</h2>
          <p>Biblioteca de ícones em 4 categorias: Geometric (patterns), Civic (silhuetas), Folk (linha xilográfica), Cotidiano (objetos brasileiros).</p>
          <footer>Ver icons →</footer>
        </a>
      </article>
      <article data-interactive>
        <a href="/cobogo/foundations/themes/">
          <h2>Themes &amp; Textures</h2>
          <p>Variantes tonais (lambe-lambe, carimbo, boteco, faixa de caminhão) e texturas (papel velho, concreto, palha).</p>
          <footer>Ver themes →</footer>
        </a>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 1240px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  main > [data-page-header] {
    margin-bottom: 4rem;
    max-width: 720px;
  }
  main > [data-page-header] hgroup h1 {
    font-size: var(--t-h1);
    margin: 1rem 0 1.5rem;
    line-height: var(--lh-tight);
  }
  main > [data-page-header] hgroup p:last-child {
    font-size: var(--t-lede);
    color: var(--fg-muted);
    line-height: var(--lh-body);
  }

  [data-foundations-grid] {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    padding: 0;
    border: 0;
  }
  [data-foundations-grid] article {
    padding: 0;
    border: 1px solid var(--border);
    box-shadow: none;
    background: var(--bg-raised);
    transition: transform var(--dur-2) var(--ease-out), border-color var(--dur-2) var(--ease-out);
  }
  [data-foundations-grid] article:hover { transform: translateY(-2px); border-color: var(--accent); }
  [data-foundations-grid] a {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }
  [data-foundations-grid] h2 { font-size: var(--t-h3); margin: 0; }
  [data-foundations-grid] p { color: var(--fg-muted); margin: 0; font-size: var(--t-body); line-height: var(--lh-body); }
  [data-foundations-grid] footer {
    margin-top: auto;
    color: var(--accent);
    font-weight: 700;
    font-size: var(--t-small);
    background: transparent;
    padding: 0;
    border: 0;
  }

  @media (max-width: 768px) {
    main > [data-page-header] hgroup h1 { font-size: clamp(2.5rem, 8vw, var(--t-h1)); }
    main > [data-page-header] hgroup p:last-child { font-size: clamp(1rem, 4vw, var(--t-lede)); }
  }
</style>
