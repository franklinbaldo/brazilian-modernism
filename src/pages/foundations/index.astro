---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Foundations | COBOGÓ">
  <div class="wrap" style="padding: 4rem 0;">
    <header class="page-header">
      <span class="kicker">Foundations</span>
      <h1>Fundações do COBOGÓ</h1>
      <p class="lede">
        Tokens, tipografia, ícones, themes e texturas brasileiras —
        a base da gramática visual do design system.
      </p>
    </header>

    <div class="cards-grid">
      <a class="card" href="/cobogo/docs/foundations/tokens/">
        <h2>Tokens</h2>
        <p>Paleta papel/concreto + primárias saturadas, semânticos, escalas tipográficas, radius, shadows e motion.</p>
        <span class="card-link">Ver tokens →</span>
      </a>

      <a class="card" href="/cobogo/foundations/typography/">
        <h2>Typography</h2>
        <p>Archivo, Fraunces, Piazzolla, JetBrains Mono — mais display fonts brasileiros: Caveat (letreiro), PT Serif Caption (jornal), Bevan (cordel).</p>
        <span class="card-link">Ver typography →</span>
      </a>

      <a class="card" href="/cobogo/foundations/icons/">
        <h2>Icons</h2>
        <p>Biblioteca de ícones em 4 categorias: Geometric (patterns), Civic (silhuetas), Folk (linha xilográfica), Cotidiano (objetos brasileiros).</p>
        <span class="card-link">Ver icons →</span>
      </a>

      <a class="card" href="/cobogo/foundations/themes/">
        <h2>Themes & Textures</h2>
        <p>Variantes tonais (lambe-lambe, carimbo, boteco, faixa de caminhão) e texturas (papel velho, concreto, palha).</p>
        <span class="card-link">Ver themes →</span>
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 4rem;
    max-width: 720px;
  }
  .kicker {
    font-size: var(--t-small);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 1rem;
    display: block;
  }
  h1 {
    font-size: var(--t-h1);
    margin-bottom: 1.5rem;
    line-height: var(--lh-tight);
  }
  .lede {
    font-size: var(--t-lede);
    color: var(--fg-muted);
    line-height: var(--lh-body);
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--r-soft);
    text-decoration: none;
    color: inherit;
    transition: transform var(--dur-2) var(--ease-out), border-color var(--dur-2) var(--ease-out);
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }
  .card h2 {
    font-size: var(--t-h3);
    margin: 0;
  }
  .card p {
    color: var(--fg-muted);
    margin: 0;
    font-size: var(--t-body);
    line-height: var(--lh-body);
  }
  .card-link {
    margin-top: auto;
    color: var(--accent);
    font-weight: 700;
    font-size: var(--t-small);
  }

  @media (max-width: 768px) {
    h1 {
      font-size: clamp(2.5rem, 8vw, var(--t-h1));
    }
    .lede {
      font-size: clamp(1rem, 4vw, var(--t-lede));
    }
  }
</style>
