---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.svelte';
import Card from '../components/Card.svelte';
import Badge from '../components/Badge.svelte';
---

<BaseLayout title="Brazilian Modernism | Design System">
  <main>
    <!-- HERO SECTION -->
    <header class="hero azulejo-soft azulejo-grade">
      <div class="container hero-content">
        <p class="tracked-caps">Franklin Baldo apresenta</p>
        <h1 class="hero-title font-logo">Verne & Modernismo</h1>
        <p class="hero-subtitle">Um design system unificado inspirado na arquitetura brasileira: <strong>Curva & Concreto</strong>.</p>
        <div class="hero-actions">
          <Button>Começar Agora</Button>
          <a href="#componentes" class="secondary-link tracked-caps">Ver Componentes</a>
        </div>
      </div>
      <div class="hero-curve"></div>
    </header>

    <div class="container">
      <!-- DOCTRINE SECTION -->
      <section class="doctrine-section">
        <div class="doctrine-grid">
          <div class="doctrine-text">
            <h2 class="section-title">A Doutrina</h2>
            <p class="body-lede">O modernismo brasileiro é o equilíbrio entre a fluidez da curva e a honestidade do concreto bruto.</p>
            <p>Nossa interface segue este princípio rigorosamente: a curva é para o usuário (navegação, botões, feedback); o concreto é para os dados (tabelas, cards, blocos de informação).</p>
          </div>
          <div class="doctrine-card azulejo-soft azulejo-xadrez-bulcao">
            <h3 class="font-display">Niemeyer & Bulcão</h3>
            <p>Inspirado nas curvas de Oscar Niemeyer e nos azulejos modulares de Athos Bulcão.</p>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- TOKENS SECTION -->
      <section id="tokens">
        <h2 class="section-title">Design Tokens</h2>
        
        <div class="token-group">
          <h3 class="tracked-caps">Cores (Bossa Nova & Volpi)</h3>
          <div class="color-grid">
            <div class="color-swatch" style="background: var(--color-bg);">
              <span class="color-label tracked-caps">Papel (Background)</span>
              <code class="font-mono">#F4EFE4</code>
            </div>
            <div class="color-swatch" style="background: var(--color-surface);">
              <span class="color-label tracked-caps">Concreto (Surface)</span>
              <code class="font-mono">#EAE2CE</code>
            </div>
            <div class="color-swatch swatch-dark" style="background: var(--color-accent);">
              <span class="color-label tracked-caps">Vermelho Volpi (Accent)</span>
              <code class="font-mono">#C2281F</code>
            </div>
            <div class="color-swatch swatch-dark" style="background: var(--color-azul);">
              <span class="color-label tracked-caps">Céu de Brasília (Azul)</span>
              <code class="font-mono">#1F6FA8</code>
            </div>
            <div class="color-swatch swatch-dark" style="background: var(--color-verde);">
              <span class="color-label tracked-caps">Mata Verde</span>
              <code class="font-mono">#3F7A4E</code>
            </div>
            <div class="color-swatch" style="background: var(--color-ouro);">
              <span class="color-label tracked-caps">Areia de Copacabana</span>
              <code class="font-mono">#D8A43A</code>
            </div>
          </div>
        </div>

        <div class="token-group">
          <h3 class="tracked-caps">Tipografia</h3>
          <div class="typo-demo">
            <div class="typo-row">
              <span class="typo-label tracked-caps">Logo / Display</span>
              <h1 class="font-logo" style="font-size: 3rem;">Brazilian Modernism</h1>
            </div>
            <div class="typo-row">
              <span class="typo-label tracked-caps">Display Secundário</span>
              <h2 class="font-display" style="font-size: 2.5rem;">Curva & Concreto</h2>
            </div>
            <div class="typo-row">
              <span class="typo-label tracked-caps">Corpo do Texto</span>
              <p style="max-width: 600px;">Manrope é nossa fonte de leitura. Ela traz modernidade e clareza para interfaces densas de dados, mantendo um ritmo harmônico e arejado.</p>
            </div>
            <div class="typo-row">
              <span class="typo-label tracked-caps">Monoespaçada</span>
              <code class="font-mono">JetBrains Mono para código e dados brutos.</code>
            </div>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- COMPONENTS SECTION -->
      <section id="componentes">
        <h2 class="section-title">Componentes</h2>
        
        <div class="component-grid">
          <!-- BUTTONS -->
          <div class="component-card">
            <h3 class="tracked-caps">Botões (A Curva)</h3>
            <p>Curvas parabólicas (radius-pill) para ações do usuário.</p>
            <div class="demo-area">
              <Button>Ação Principal</Button>
              <Button variant="outline">Secundário</Button>
            </div>
          </div>

          <!-- BADGES -->
          <div class="component-card">
            <h3 class="tracked-caps">Badges (O Concreto)</h3>
            <p>Geometria rígida (radius-0) para tags e metadados.</p>
            <div class="demo-area">
              <Badge variant="azul">Processando</Badge>
              <Badge variant="verde">Sucesso</Badge>
              <Badge variant="ouro">Atenção</Badge>
            </div>
          </div>
        </div>

        <div class="token-group">
          <h3 class="tracked-caps">Cards & Azulejos (Estrutura)</h3>
          <div class="card-demo-grid">
            <Card pattern="triangulos">
              <h4 class="font-display">Athos Triângulos</h4>
              <p>Cards com padrões Bulcão em baixa opacidade para textura sutil.</p>
              <div class="card-footer">
                <Button variant="small">Explorar</Button>
              </div>
            </Card>

            <Card pattern="meias-luas">
              <h4 class="font-display">Meias Luas</h4>
              <p>A tensão entre o geométrico e o orgânico em cada interface.</p>
              <div class="card-footer">
                <Badge variant="azul">Ativo</Badge>
              </div>
            </Card>

            <Card pattern="xadrez-bulcao">
              <h4 class="font-display">Xadrez Bulcão</h4>
              <p>Módulos repetitivos que formam uma unidade estética coesa.</p>
              <div class="card-footer">
                <code class="font-mono">v1.0.0</code>
              </div>
            </Card>
          </div>
        </div>
      </section>
    </div>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="container footer-content">
        <div class="footer-brand">
          <span class="font-logo">Verne</span>
          <p class="tracked-caps">© 2026 Franklin Baldo</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/franklinbaldo/brazilian-modernism" class="tracked-caps">Repositório</a>
          <a href="https://github.com/franklinbaldo/verne" class="tracked-caps">Verne CLI</a>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    padding: 8rem 0 12rem;
    position: relative;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .hero-content {
    position: relative;
    z-index: 10;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.9;
    margin: 1rem 0 2rem;
    color: var(--color-text);
  }

  .hero-subtitle {
    font-size: 1.5rem;
    max-width: 600px;
    margin-bottom: 3rem;
    color: var(--color-text-dim);
  }

  .hero-actions {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .secondary-link {
    text-decoration: none;
    color: var(--color-text);
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 2px;
    transition: var(--duration-snap) var(--ease-curva);
  }

  .secondary-link:hover {
    color: var(--color-accent);
  }

  .hero-curve {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 100px;
    background-color: var(--color-bg);
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  }

  /* DOCTRINE */
  .doctrine-section {
    padding: 6rem 0;
  }

  .doctrine-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .doctrine-card {
    background-color: var(--color-surface);
    padding: 3rem;
    border-radius: var(--radius-arch) 0 0 0;
    box-shadow: var(--shadow-pool);
  }

  .body-lede {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-text);
    font-family: var(--font-display);
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin-bottom: 2.5rem;
    color: var(--color-text);
  }

  /* TOKENS */
  .token-group {
    margin: 4rem 0;
  }

  .token-group h3 {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .color-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .color-swatch {
    height: 140px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .swatch-dark {
    color: white;
  }

  .swatch-dark code {
    color: rgba(255,255,255,0.8);
  }

  .color-label {
    font-size: 0.7rem;
    margin-bottom: 0.5rem;
    display: block;
  }

  .typo-demo {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .typo-label {
    display: block;
    margin-bottom: 0.5rem;
  }

  /* COMPONENTS */
  .component-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .component-card {
    background: var(--color-surface);
    padding: 2.5rem;
    border: 1px solid var(--color-border);
  }

  .demo-area {
    margin-top: 2rem;
    padding: 2rem;
    background: var(--color-bg);
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .card-demo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .card-footer {
    margin-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* FOOTER */
  .site-footer {
    margin-top: 10rem;
    padding: 6rem 0;
    background: var(--color-text);
    color: var(--color-bg);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .footer-brand span {
    font-size: 3rem;
    display: block;
    line-height: 1;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    color: var(--color-bg);
    text-decoration: none;
    opacity: 0.7;
    transition: 150ms;
  }

  .footer-links a:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .hero { padding: 4rem 0 8rem; }
    .doctrine-grid { grid-template-columns: 1fr; }
    .doctrine-card { border-radius: 0; }
    .component-grid { grid-template-columns: 1fr; }
  }
</style>
