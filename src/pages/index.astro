---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ornaments from '../components/Ornaments.astro';
---

<BaseLayout title="Instituto Brasil Moderno | Patrimônio, Cidade e Futuro">
  <div class="app-wrapper">
    <aside class="tile-sidebar">
      <div class="sidebar-tiles pattern-bulcao"></div>
    </aside>

    <main class="main-content">
      <nav class="container site-nav">
        <div class="nav-brand font-logo">Instituto Brasil Moderno</div>
        <div class="nav-links">
          <a href="/cobogo/manifesto/">Manifesto</a>
          <a href="/cobogo/componentes/">Componentes</a>
          <a href="#">Arquitetura</a>
          <a href="#">Design</a>
        </div>
        <div class="nav-actions">
          <button class="link">Buscar</button>
          <a href="#" class="btn btn--azul">Seja membro</a>
        </div>
      </nav>

      <section class="hero">
        <div class="hero__inner wrap">
          <div class="hero__copy">
            <span class="kicker kicker--vermelho">Patrimônio, cidade e futuro</span>
            <h1 class="hero__title">
              Modernismo brasileiro como <em>espaço</em>, cultura e vida pública.
            </h1>
            <p class="hero__lead">
              Arquitetura, design, arte e memória que conectam passado, presente e
              futuro para construir cidades mais humanas.
            </p>
            <div class="hero__cta">
              <a href="#" class="btn btn--azul btn--lg">
                Explorar acervo <span class="btn__arrow">→</span>
              </a>
              <a href="#" class="btn btn--secondary btn--lg">
                Planejar visita <span class="btn__arrow">→</span>
              </a>
            </div>
          </div>

          <div class="hero__art">
            <Ornaments type="landscape" />
          </div>
        </div>
      </section>

      <section class="pillars">
        <div class="wrap pillars__grid">
          <a class="pillar pillar--azul" href="#">
            <div class="pillar__icon">
              <Ornaments type="pillar" name="acervo" size={28} color="var(--papel-00)" />
            </div>
            <div class="pillar__body">
              <div class="pillar__title">Acervo</div>
              <p class="pillar__desc">Explore nosso acervo digital com milhares de obras, documentos e imagens históricas.</p>
            </div>
            <span class="pillar__arrow">→</span>
          </a>
          <a class="pillar pillar--verde" href="#">
            <div class="pillar__icon">
              <Ornaments type="pillar" name="exposicoes" size={28} color="var(--papel-00)" />
            </div>
            <div class="pillar__body">
              <div class="pillar__title">Exposições</div>
              <p class="pillar__desc">Confira as exposições em cartaz e as próximas mostras temporárias e itinerantes.</p>
            </div>
            <span class="pillar__arrow">→</span>
          </a>
          <a class="pillar pillar--vermelho" href="#">
            <div class="pillar__icon">
              <Ornaments type="pillar" name="educacao" size={28} color="var(--papel-00)" />
            </div>
            <div class="pillar__body">
              <div class="pillar__title">Educação</div>
              <p class="pillar__desc">Programas, cursos e conteúdos para todas as idades sobre o modernismo brasileiro.</p>
            </div>
            <span class="pillar__arrow">→</span>
          </a>
          <a class="pillar pillar--ocre" href="#">
            <div class="pillar__icon">
              <Ornaments type="pillar" name="cidade" size={28} color="var(--papel-00)" />
            </div>
            <div class="pillar__body">
              <div class="pillar__title">Cidade</div>
              <p class="pillar__desc">Projetos e pesquisas sobre a cidade, o patrimônio e a vida pública contemporânea.</p>
            </div>
            <span class="pillar__arrow">→</span>
          </a>
        </div>
      </section>

      <section class="statsband">
        <div class="statsband__stats wrap">
          <div class="bigstat">
            <div class="bigstat__n">12K+</div>
            <div class="bigstat__label">obras no acervo</div>
          </div>
          <div class="bigstat">
            <div class="bigstat__n">860+</div>
            <div class="bigstat__label">arquitetos e designers</div>
          </div>
          <div class="bigstat">
            <div class="bigstat__n">48</div>
            <div class="bigstat__label">exposições em cartaz</div>
          </div>
          <div class="bigstat">
            <div class="bigstat__n">98K+</div>
            <div class="bigstat__label">visitantes por ano</div>
          </div>
        </div>
      </section>

      <section class="news">
        <div class="wrap news__head">
          <div class="news__intro">
            <span class="kicker">Novidades</span>
            <h2 class="news__title">Em <em>movimento</em>.</h2>
            <p class="news__lead">
              Acompanhe notícias, exposições, programas e pesquisas
              que mantêm o modernismo vivo e atual.
            </p>
            <a class="link" href="#">
              Ver todas as notícias <span>→</span>
            </a>
          </div>
          <div class="news__grid">
            <article class="newscard">
              <div class="newscard__art">
                <Ornaments type="landscape" />
              </div>
              <div class="newscard__meta">24 MAIO 2026</div>
              <h3 class="newscard__title">Nova exposição destaca Oscar Niemeyer e a arquitetura de Brasília</h3>
              <span class="newscard__kicker">Exposição</span>
            </article>
            <article class="newscard">
              <div class="newscard__art">
                 <div style="background: var(--verde); width: 100%; height: 100%;"></div>
              </div>
              <div class="newscard__meta">10 MAIO 2026</div>
              <h3 class="newscard__title">Burle Marx: natureza, desenho e paisagem moderna</h3>
              <span class="newscard__kicker">Pesquisa</span>
            </article>
          </div>
        </div>
      </section>

      <section class="quotesec">
        <div class="wrap quotesec__inner">
          <div class="quotesec__deco">
            <Ornaments type="landscape" />
          </div>
          <blockquote class="quotesec__q">
            <p>
              “A cidade é, antes de tudo, feita de encontros, de caminhos e de
              memória. Design é serviço público.”
            </p>
            <footer>
              <span class="quotesec__author">Lina Bo Bardi</span>
              <span class="quotesec__role">arquiteta · 1914–1992</span>
            </footer>
          </blockquote>
        </div>
      </section>

      <footer class="site-footer">
        <div class="wrap">
          <p>© 2026 Instituto Brasil Moderno. Todos os direitos reservados.</p>
        </div>
      </footer>
    </main>
  </div>
</BaseLayout>

<style>
  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
  }

  .nav-brand {
    font-size: 1.5rem;
    font-weight: 800;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    text-decoration: none;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .hero__art {
    aspect-ratio: 4/3;
    border-radius: var(--r-soft);
    overflow: hidden;
    box-shadow: var(--shadow-2);
    border: 1px solid var(--concreto-90);
  }

  .quotesec__deco {
    aspect-ratio: 3/2;
    border-radius: var(--r-soft);
    overflow: hidden;
    box-shadow: var(--shadow-1);
  }
</style>
