---
import BaseLayout from '../layouts/BaseLayout.astro';
import CobogoCircular from '../components/patterns/CobogoCircular.svelte';
import CobogoHexagonal from '../components/patterns/CobogoHexagonal.svelte';
import CobogoLosango from '../components/patterns/CobogoLosango.svelte';
import CobogoCruz from '../components/patterns/CobogoCruz.svelte';
import Button from '../components/Button.svelte';
import Badge from '../components/Badge.svelte';
import Alert from '../components/Alert.svelte';

const colors = [
  { name: '--papel-00',    hex: '#FBF8F1' },
  { name: '--papel-20',    hex: '#EDE7D8' },
  { name: '--concreto-60', hex: '#6B6455' },
  { name: '--concreto-90', hex: '#1A1814' },
  { name: '--azul',        hex: '#1B2B4B' },
  { name: '--vermelho',    hex: '#C8472E' },
  { name: '--ocre',        hex: '#D9A441' },
  { name: '--verde',       hex: '#2E6B4A' },
];
---

<BaseLayout title="COBOGÓ — Galeria">
  <header data-region="site-header">
    <nav>
      <ul><li><strong>COBOGÓ</strong></li></ul>
      <ul>
        <li><a href="#patterns">Padrões</a></li>
        <li><a href="#tokens">Tokens</a></li>
        <li><a href="#components">Componentes</a></li>
        <li><a href="/cobogo/manifesto/">Manifesto</a></li>
        <li><a href="/cobogo/docs/getting-started/">Docs</a></li>
        <li><a href="https://github.com/franklinbaldo/cobogo" role="button">Github</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <!-- Wall: the artwork is the pitch. -->
    <section data-section="wall" aria-labelledby="wall-title">
      <div data-region="wall-art" aria-hidden="true">
        <CobogoCircular tile={true} size={120} color="var(--papel-00)" density={0.18} />
      </div>
      <hgroup>
        <h1 id="wall-title">COBOGÓ</h1>
        <p>Um sistema visual brasileiro, escrito em HTML semântico sobre <a href="https://picocss.com/">Pico CSS</a>.</p>
      </hgroup>
    </section>

    <!-- Patterns gallery: the namesake, full size. -->
    <section id="patterns" aria-labelledby="patterns-title">
      <hgroup>
        <h2 id="patterns-title">Padrões</h2>
        <p>Quatro cobogós tileáveis. Renderizados em SVG, controlados por <code>size</code>, <code>color</code>, <code>density</code>.</p>
      </hgroup>

      <div data-region="pattern-grid">
        <figure data-pattern-card>
          <div data-region="pattern-tile">
            <CobogoCircular tile={true} size={96} color="var(--azul)" density={0.5} />
          </div>
          <figcaption><strong>Circular</strong><small>A curva. Niemeyer.</small></figcaption>
        </figure>
        <figure data-pattern-card>
          <div data-region="pattern-tile">
            <CobogoHexagonal tile={true} size={96} color="var(--vermelho)" density={0.5} />
          </div>
          <figcaption><strong>Hexagonal</strong><small>A colmeia. Bulcão.</small></figcaption>
        </figure>
        <figure data-pattern-card>
          <div data-region="pattern-tile">
            <CobogoLosango tile={true} size={96} color="var(--ocre)" density={0.5} />
          </div>
          <figcaption><strong>Losango</strong><small>A calçada. Burle Marx.</small></figcaption>
        </figure>
        <figure data-pattern-card>
          <div data-region="pattern-tile">
            <CobogoCruz tile={true} size={96} color="var(--verde)" density={0.5} />
          </div>
          <figcaption><strong>Cruz</strong><small>A grelha. Costa.</small></figcaption>
        </figure>
      </div>
    </section>

    <!-- Tokens: color, type, radius, shadow specimens. -->
    <section id="tokens" aria-labelledby="tokens-title">
      <hgroup>
        <h2 id="tokens-title">Tokens</h2>
        <p>Definidos uma vez, mapeados em <code>--pico-*</code>. Componentes nunca leem cor crua.</p>
      </hgroup>

      <h3>Cor</h3>
      <dl data-region="swatches">
        {colors.map(({ name, hex }) => (
          <>
            <dt><span data-region="swatch" style={`background:var(${name})`} aria-hidden="true"></span>{name}</dt>
            <dd><code data-token-value={name}>{hex}</code></dd>
          </>
        ))}
      </dl>

      <script is:inline>
        (() => {
          const update = () => {
            const cs = getComputedStyle(document.documentElement);
            for (const el of document.querySelectorAll('[data-token-value]')) {
              const v = cs.getPropertyValue(el.getAttribute('data-token-value')).trim();
              if (v) el.textContent = v;
            }
          };
          update();
          new MutationObserver(update).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'class'] });
        })();
      </script>

      <h3>Tipografia</h3>
      <figure data-region="type-specimen">
        <p style="font: 800 var(--t-display)/1 var(--font-display); letter-spacing:-0.04em">Aa</p>
        <p style="font: 800 var(--t-h1)/1.05 var(--font-display)">Modernismo brasileiro</p>
        <p style="font: 400 var(--t-h2)/1.1 var(--font-display-alt); font-style: italic">traduzido em interface</p>
        <p style="font: 400 var(--t-lede)/1.5 var(--font-sans); color: var(--fg-muted)">Lede em Archivo: a tipografia carrega o ritmo cívico do sistema.</p>
        <p style="font: 400 var(--t-body)/1.6 var(--font-serif)">Corpo em Piazzolla, com serifa para densidade documental.</p>
        <p style="font: 700 var(--t-small)/1.4 var(--font-sans); text-transform:uppercase; letter-spacing:0.1em">Micro · kicker · micro</p>
      </figure>

      <h3>Raio &amp; Sombra</h3>
      <div data-region="elevation">
        <figure>
          <div style="border-radius: var(--r-1); background: var(--azul); box-shadow: var(--shadow-1)"></div>
          <figcaption><code>--r-1</code> · <code>--shadow-1</code></figcaption>
        </figure>
        <figure>
          <div style="border-radius: var(--r-soft); background: var(--vermelho); box-shadow: var(--shadow-2)"></div>
          <figcaption><code>--r-soft</code> · <code>--shadow-2</code></figcaption>
        </figure>
        <figure>
          <div style="border-radius: var(--r-pill); background: var(--ocre)"></div>
          <figcaption><code>--r-pill</code></figcaption>
        </figure>
      </div>
    </section>

    <!-- Components: live, semantic. -->
    <section id="components" aria-labelledby="components-title">
      <hgroup>
        <h2 id="components-title">Componentes</h2>
        <p>HTML semântico, classes proibidas. Variantes via <code>data-intent</code>.</p>
      </hgroup>

      <article>
        <header><h3>Botões</h3></header>
        <p>
          <Button intent="primary">Primário</Button>{' '}
          <Button intent="secondary">Secundário</Button>{' '}
          <Button intent="outline">Outline</Button>{' '}
          <Button intent="link">Link</Button>
        </p>
      </article>

      <article>
        <header><h3>Badges</h3></header>
        <p>
          <Badge intent="azul">Info</Badge>{' '}
          <Badge intent="verde">Sucesso</Badge>{' '}
          <Badge intent="ocre">Atenção</Badge>{' '}
          <Badge intent="vermelho">Erro</Badge>{' '}
          <Badge intent="neutral">Neutro</Badge>
        </p>
      </article>

      <article>
        <header><h3>Alertas</h3></header>
        <Alert intent="info" title="Info">Painel cívico publicado.</Alert>
        <Alert intent="success" title="Sucesso">Compra pública indexada.</Alert>
        <Alert intent="warning" title="Atenção">Dado parcial — fonte em revisão.</Alert>
        <Alert intent="danger" title="Erro">Falha ao carregar série temporal.</Alert>
      </article>

      <article>
        <header><h3>Formulário</h3></header>
        <form onsubmit="event.preventDefault()">
          <label>
            Buscar contrato
            <input type="search" placeholder="ex.: Secretaria de Saúde" />
          </label>
          <label>
            Órgão
            <select>
              <option>Todos</option>
              <option>Educação</option>
              <option>Saúde</option>
              <option>Transporte</option>
            </select>
          </label>
          <fieldset>
            <legend>Período</legend>
            <label><input type="radio" name="p" checked /> 30 dias</label>
            <label><input type="radio" name="p" /> 90 dias</label>
            <label><input type="radio" name="p" /> Tudo</label>
          </fieldset>
          <Button intent="primary">Buscar</Button>
        </form>
      </article>

      <article>
        <header><h3>Tabela</h3></header>
        <figure>
          <table>
            <thead>
              <tr><th>Órgão</th><th>Contrato</th><th>Valor</th><th>Status</th></tr>
            </thead>
            <tbody>
              <tr><td>Saúde</td><td>Insumos UBS</td><td>R$ 1.240.000</td><td><Badge intent="verde">Ativo</Badge></td></tr>
              <tr><td>Educação</td><td>Merenda escolar</td><td>R$ 980.500</td><td><Badge intent="ocre">Em análise</Badge></td></tr>
              <tr><td>Transporte</td><td>Sinalização viária</td><td>R$ 432.100</td><td><Badge intent="vermelho">Suspenso</Badge></td></tr>
            </tbody>
          </table>
        </figure>
      </article>
    </section>
  </main>

  <footer data-region="site-footer">
    <p>© 2026 COBOGÓ — sistema visual aberto para interfaces públicas. <a href="https://github.com/franklinbaldo/cobogo">Código no GitHub</a>.</p>
  </footer>
</BaseLayout>

<style>
  /* Header — keep it boring; Pico already styles nav+ul. */
  [data-region="site-header"] {
    border-bottom: 1px solid var(--border);
    padding: 1rem clamp(1rem, 4vw, 2rem);
  }
  [data-region="site-header"] strong {
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: -0.04em;
    font-size: 1.25rem;
  }

  main { max-width: 1180px; margin: 0 auto; padding: 0 clamp(1rem, 4vw, 2rem); }
  main > section { padding-block: clamp(3rem, 8vw, 6rem); }
  main > section + section { border-top: 1px solid var(--border); }
  main > section > hgroup { margin-bottom: 2.5rem; }
  main > section > hgroup h2 { font-family: var(--font-display); font-size: var(--t-h2); margin: 0 0 .5rem; }
  main > section > hgroup p { color: var(--fg-muted); max-width: 60ch; margin: 0; }
  main h3 { font-family: var(--font-display); margin-top: 2.5rem; }

  /* Wall hero */
  [data-section="wall"] {
    position: relative;
    isolation: isolate;
    padding-block: clamp(5rem, 14vw, 9rem);
    text-align: left;
  }
  [data-region="wall-art"] {
    position: absolute; inset: 0; z-index: -1;
    background: var(--azul);
    overflow: hidden;
  }
  [data-region="wall-art"] > :global(div) { width: 100%; height: 100%; opacity: 0.9 !important; }
  /* Wall background is theme-invariant (--azul stays dark in both themes),
     so text uses fixed light values rather than --papel-* tokens that flip. */
  [data-section="wall"] hgroup h1 {
    font-family: var(--font-display);
    font-size: var(--t-display);
    line-height: .9;
    letter-spacing: -0.05em;
    color: #FBF8F1;
    margin: 0 0 1rem;
  }
  [data-section="wall"] hgroup p { color: #EDE7D8; max-width: 48ch; font-size: var(--t-lede); margin: 0; }
  [data-section="wall"] hgroup p a { color: #FBF8F1; }

  /* Patterns */
  [data-region="pattern-grid"] {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  [data-pattern-card] { margin: 0; background: var(--bg-raised); display: flex; flex-direction: column; }
  [data-region="pattern-tile"] {
    aspect-ratio: 1;
    background: var(--papel-20);
    position: relative;
    overflow: hidden;
  }
  [data-region="pattern-tile"] > :global(div) { position: absolute; inset: 0; opacity: 0.65 !important; }
  [data-pattern-card] figcaption { padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: .25rem; }
  [data-pattern-card] figcaption strong { font-family: var(--font-display); font-size: 1.125rem; }
  [data-pattern-card] figcaption small { color: var(--fg-muted); }

  /* Tokens — swatches */
  [data-region="swatches"] {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: .5rem 2rem;
  }
  [data-region="swatches"] dt {
    display: flex; align-items: center; gap: .75rem;
    font-weight: 600;
  }
  [data-region="swatches"] dd { margin: 0 0 .5rem 2.25rem; color: var(--fg-muted); }
  [data-region="swatch"] {
    display: inline-block; width: 1.5rem; height: 1.5rem;
    border: 1px solid var(--border); border-radius: var(--r-1);
  }

  [data-region="type-specimen"] { margin: 0; }
  [data-region="type-specimen"] > p { margin: 0 0 1.25rem; }

  [data-region="elevation"] {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
  }
  [data-region="elevation"] figure { margin: 0; }
  [data-region="elevation"] div { width: 100%; aspect-ratio: 3/2; }
  [data-region="elevation"] figcaption { margin-top: 1rem; color: var(--fg-muted); font-size: var(--t-small); }

  /* Components — let Pico style article/form/table; just add rhythm */
  [id="components"] > article { margin-bottom: 2rem; }
  [id="components"] > article > p { display: flex; flex-wrap: wrap; gap: .75rem; align-items: center; }

  [data-region="site-footer"] {
    padding: 2.5rem clamp(1rem, 4vw, 2rem);
    border-top: 1px solid var(--border);
    color: var(--fg-muted);
    max-width: 1180px;
    margin: 0 auto;
  }
</style>
