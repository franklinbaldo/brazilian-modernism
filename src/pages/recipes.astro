---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.svelte';
import ProfileCard from '../components/ProfileCard.svelte';
import DataTable from '../components/DataTable.svelte';
import SearchBar from '../components/SearchBar.svelte';
---

<BaseLayout title="Recipes | COBOGÓ">
  <div class="app-wrapper">
    <main class="main-content">
      <nav class="container site-nav">
        <div class="nav-brand font-logo">COBOGÓ</div>
        <div class="nav-links">
          <a href="/cobogo/">Home</a>
          <a href="/cobogo/manifesto/">Manifesto</a>
          <a href="/cobogo/componentes/">Components</a>
          <a href="/cobogo/patterns/">Patterns</a>
          <a href="/cobogo/recipes/" class="active">Recipes</a>
        </div>
      </nav>

      <header class="container page-header">
        <h1 class="display-serif">Recipes</h1>
        <p class="lede">Composições reusáveis dos componentes COBOGÓ aplicadas a casos cívicos.</p>
      </header>

      <!-- Recipe 1: Painel cívico de transparência -->
      <section class="container component-section">
        <h2 class="section-title">Painel cívico de transparência</h2>
        <p class="section-desc">Dashboard com cards de métricas (mocks).</p>

        <div class="recipe-grid-3">
          <div class="metric-card-mock">
            <span class="metric-value">R$ 4.2M</span>
            <span class="metric-label">contratos ativos</span>
          </div>
          <div class="metric-card-mock">
            <span class="metric-value">127</span>
            <span class="metric-label">fornecedores únicos</span>
          </div>
          <div class="metric-card-mock">
            <span class="metric-value">23</span>
            <span class="metric-label">contratos vencendo em 30 dias</span>
          </div>
        </div>
      </section>

      <!-- Recipe 2: Busca pública densa -->
      <section class="container component-section">
        <h2 class="section-title">Busca pública densa</h2>
        <p class="section-desc">Layout de 2 colunas com busca/filtros e tabela de resultados.</p>

        <div class="recipe-layout-2col">
          <aside class="sidebar-280">
            <SearchBar
              client:load
              placeholder="Buscar contratos..."
              filters={[
                { id: 'ativos', label: 'Ativos', active: true },
                { id: 'encerrados', label: 'Encerrados', active: false },
                { id: 'pncp', label: 'PNCP', active: true }
              ]}
            />
          </aside>
          <div class="main-col">
            <DataTable
              client:load
              caption="Resultados da busca: Contratos PNCP"
              headers={[
                { key: 'id', label: 'ID Contrato' },
                { key: 'objeto', label: 'Objeto' },
                { key: 'valor', label: 'Valor', align: 'right' },
                { key: 'status', label: 'Status', align: 'center' }
              ]}
              data={[
                { id: 'CT-2023-001', objeto: 'Aquisição de equipamentos de TI', valor: 'R$ 150.000,00', status: 'Ativo' },
                { id: 'CT-2023-042', objeto: 'Serviços de limpeza terceirizada', valor: 'R$ 45.200,00', status: 'Ativo' },
                { id: 'CT-2022-199', objeto: 'Manutenção de frota de veículos', valor: 'R$ 89.000,00', status: 'Concluído' },
                { id: 'CT-2023-088', objeto: 'Licenciamento de software ERP', valor: 'R$ 210.000,00', status: 'Pendente' },
                { id: 'CT-2021-005', objeto: 'Obras de reforma do telhado', valor: 'R$ 1.250.000,00', status: 'Cancelado' }
              ]}
            />
          </div>
        </div>
      </section>

      <!-- Recipe 3: Perfil de entidade pública -->
      <section class="container component-section">
        <h2 class="section-title">Perfil de entidade pública</h2>
        <p class="section-desc">Card de perfil acompanhado de dados detalhados.</p>

        <div class="recipe-layout-profile">
          <aside class="profile-col">
            <ProfileCard
              client:load
              name="Prefeitura Municipal"
              role="Entidade Executiva"
              tags={['CNPJ', 'Ativo']}
            />
          </aside>
          <div class="details-col">
            <Card class="mb-4">
              <h3 class="card-heading">Dados Gerais</h3>
              <p><strong>CNPJ:</strong> 00.000.000/0001-00</p>
              <p><strong>Endereço:</strong> Praça da Matriz, s/n - Centro</p>
            </Card>
            <Card class="mb-4">
              <h3 class="card-heading">Contratos Vinculados</h3>
              <p>15 contratos ativos registrados no sistema.</p>
            </Card>
            <Card>
              <h3 class="card-heading">Score de Transparência</h3>
              <p>Nota: <strong>8.5/10</strong></p>
            </Card>
          </div>
        </div>
      </section>

      <!-- Recipe 4: Longform jurídico denso -->
      <section class="container component-section">
        <h2 class="section-title">Longform jurídico denso</h2>
        <p class="section-desc">Página de leitura longa otimizada para textos jurídicos ou normativos.</p>

        <div class="longform-container">
          <h1 class="longform-h1">Termo de Referência nº 042/2023</h1>
          <h2 class="longform-h2">1. Objeto da Contratação</h2>

          <p class="longform-p">O presente documento tem por finalidade estabelecer as condições, critérios e exigências para a contratação de empresa especializada na prestação de serviços continuados, visando o suporte técnico e a manutenção preventiva e corretiva da infraestrutura tecnológica.</p>

          <p class="longform-p">A referida contratação justifica-se pela necessidade premente de assegurar a disponibilidade, integridade e segurança das informações geridas pela Administração Pública, em consonância com os princípios da eficiência e da continuidade dos serviços públicos essenciais estabelecidos na Constituição Federal.</p>

          <blockquote class="longform-blockquote">
            "Art. 37. A administração pública direta e indireta de qualquer dos Poderes da União, dos Estados, do Distrito Federal e dos Municípios obedecerá aos princípios de legalidade, impessoalidade, moralidade, publicidade e eficiência."
          </blockquote>

          <h3 class="longform-h3">1.1. Das Obrigações da Contratada</h3>

          <p class="longform-p">A contratada deverá fornecer todo o ferramental, equipe técnica capacitada e insumos necessários à plena execução do objeto contratual. Eventuais inexecuções parciais ou totais sujeitarão a empresa às sanções administrativas previstas na Lei nº 14.133/2021 (Nova Lei de Licitações e Contratos Administrativos), sem prejuízo da reparação civil.</p>

          <pre class="longform-code"><code>{`// Exemplo de integração com API do PNCP
const response = await fetch('https://pncp.gov.br/api/pncp/v1/contratos', {
  headers: {
    'Accept': 'application/json',
    'Authorization': 'Bearer {token}'
  }
});
const data = await response.json();`}</code></pre>

          <p class="longform-p">Ressalta-se, por derradeiro, que todas as etapas de fiscalização serão conduzidas por servidor público formalmente designado para o encargo de gestor e fiscal do contrato, a quem caberá atestar as notas fiscais e relatórios de medição de serviços.</p>
        </div>
      </section>

      <footer class="container site-footer" style="padding: 4rem 0; border-top: 1px solid var(--border); margin-top: 4rem; color: var(--fg-muted);">
        <p class="tracked-caps">DS v0.1.0 — Distribuível via NPM / TypeScript Node</p>
      </footer>
    </main>
  </div>
</BaseLayout>

<style>
  .app-wrapper {
    min-height: 100vh;
    background-color: var(--bg);
    color: var(--fg);
  }

  /* Nav (Copiado do patterns.astro) */
  .site-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
  }
  .nav-brand { font-size: 1.5rem; font-weight: 800; }
  .nav-links { display: flex; gap: 2rem; font-weight: 700; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .nav-links a { color: var(--fg-muted); text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover, .nav-links a.active { color: var(--azul); }

  .font-logo { font-family: var(--font-display); font-weight: 900; text-transform: uppercase; letter-spacing: -0.05em; }

  /* Page Header */
  .page-header {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
  }
  .display-serif {
    font-family: var(--font-display-alt, var(--font-serif));
    font-size: 5rem;
    line-height: 0.9;
    margin-bottom: 2rem;
    color: var(--fg-heading);
  }
  .lede {
    font-size: 1.25rem;
    color: var(--fg-muted);
    max-width: 600px;
  }

  /* Sections */
  .component-section {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
  }
  .section-title {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
    color: var(--fg-heading);
  }
  .section-desc {
    color: var(--fg-muted);
    margin-bottom: 3rem;
  }

  /* Container utility */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Recipe 1: Grid 3 cols */
  .recipe-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .metric-card-mock {
    background-color: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--r-soft);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-1);
  }
  .metric-value {
    font-family: var(--font-display);
    font-size: var(--t-h3, 30px);
    font-weight: 800;
    color: var(--fg-heading);
    margin-bottom: 0.5rem;
  }
  .metric-label {
    font-family: var(--font-sans);
    font-size: var(--t-small, 13px);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  /* Recipe 2: Layout 2 cols */
  .recipe-layout-2col {
    display: flex;
    gap: 3rem;
  }
  .sidebar-280 {
    width: 280px;
    flex-shrink: 0;
  }
  .main-col {
    flex-grow: 1;
    min-width: 0;
  }

  /* Recipe 3: Profile Layout */
  .recipe-layout-profile {
    display: flex;
    gap: 3rem;
  }
  .profile-col {
    width: 320px;
    flex-shrink: 0;
  }
  .details-col {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .mb-4 {
    margin-bottom: 1rem;
  }
  .card-heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--fg-heading);
    margin-bottom: 0.5rem;
  }

  /* Recipe 4: Longform */
  .longform-container {
    max-width: 680px;
    margin: 0 auto;
  }
  .longform-h1 {
    font-family: var(--font-display);
    font-size: var(--t-h1, 68px);
    color: var(--fg-heading);
    margin-bottom: 2rem;
    line-height: var(--lh-tight, 0.95);
  }
  .longform-h2 {
    font-family: var(--font-display);
    font-size: var(--t-h2, 44px);
    color: var(--fg-heading);
    margin-top: 3rem;
    margin-bottom: 1.5rem;
  }
  .longform-h3 {
    font-family: var(--font-display);
    font-size: var(--t-h3, 30px);
    color: var(--fg-heading);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .longform-p {
    font-family: var(--font-serif);
    font-size: var(--t-body, 16px);
    line-height: var(--lh-body, 1.55);
    color: var(--fg);
    margin-bottom: 1.5rem;
  }
  .longform-blockquote {
    font-family: var(--font-serif);
    font-size: var(--t-h4, 22px);
    font-style: italic;
    line-height: 1.4;
    color: var(--fg-heading);
    margin: 3rem 0;
    padding: 2rem 2.5rem;
    background: var(--bg-raised);
    border-left: 4px solid var(--ocre);
    border-radius: 0 var(--r-soft) var(--r-soft) 0;
    box-shadow: var(--shadow-1);
  }
  .longform-code {
    background-color: var(--concreto-90, #1a1a1a);
    color: var(--papel-00, #ffffff);
    padding: 1.5rem;
    border-radius: var(--r-soft);
    overflow-x: auto;
    margin: 2rem 0;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .recipe-grid-3 {
      grid-template-columns: 1fr;
    }
    .recipe-layout-2col, .recipe-layout-profile {
      flex-direction: column;
    }
    .sidebar-280, .profile-col {
      width: 100%;
    }
    .display-serif {
      font-size: clamp(3rem, 8vw, 5rem);
    }
  }
</style>
