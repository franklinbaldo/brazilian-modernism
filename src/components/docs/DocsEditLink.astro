---
interface Props {
  slug: string;
}

const { slug } = Astro.props;
const editUrl = `https://github.com/franklinbaldo/cobogo/edit/main/src/content/docs/${slug}.md`;
---

<div class="edit-link-container">
  <a href={editUrl} target="_blank" rel="noopener noreferrer" class="edit-link">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pencil-icon"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
    Edit this page on GitHub
  </a>
</div>

<style>
  .edit-link-container {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--concreto-30, #e0e0e0);
  }

  .edit-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent, var(--azul));
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: var(--t-sm, 0.875rem);
    font-weight: 500;
    transition: color 0.2s;
  }

  .edit-link:hover {
    color: var(--fg, #212529);
    text-decoration: underline;
  }

  .pencil-icon {
    opacity: 0.8;
  }
</style>
