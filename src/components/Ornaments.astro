---
/* Reusable Astro components for SVG Ornaments */
interface Props {
  type: 'wave' | 'waveline' | 'calcadao' | 'mosaic' | 'landscape' | 'panel' | 'pillar';
  size?: number;
  height?: number;
  color?: string;
  name?: string;
  seed?: number;
  palette?: string[];
  className?: string;
}

const { type, size = 320, height = 40, color = "var(--concreto-90)", name, seed = 7, palette, className = "" } = Astro.props;
---

{type === 'wave' && (
  <svg viewBox="0 0 400 40" preserveAspectRatio="none" class={className} style={`display: block; width: 100%; height: ${height}px;`}>
    <path d="M0 20 C 50 0, 100 40, 200 20 S 350 0, 400 20 L 400 40 L 0 40 Z" fill={color} />
  </svg>
)}

{type === 'waveline' && (
  <svg viewBox="0 0 400 24" preserveAspectRatio="none" class={className} style={`display: block; width: 100%; height: ${height}px;`}>
    <path d="M0 12 C 25 2, 50 22, 100 12 S 175 2, 200 12 S 275 22, 300 12 S 375 2, 400 12" fill="none" stroke={color} stroke-width="1.5" />
  </svg>
)}

{type === 'calcadao' && (
  <svg viewBox="0 0 600 60" preserveAspectRatio="none" class={className} style={`display: block; width: 100%; height: ${height}px;`}>
    <rect width="600" height="60" fill="var(--papel-00)"/>
    <path d="M0 30 C 60 60, 120 0, 180 30 S 300 60, 360 30 S 480 0, 540 30 S 660 60, 720 30 L 720 60 L 0 60 Z" fill={color}/>
  </svg>
)}

{type === 'landscape' && (
  <svg viewBox="0 0 800 500" preserveAspectRatio="xMidYMid slice" class={className} style="display: block; width: 100%; height: 100%;">
    <rect width="800" height="500" fill="var(--papel-10)"/>
    <circle cx="560" cy="180" r="92" fill="var(--vermelho)"/>
    <circle cx="610" cy="220" r="58" fill="var(--ocre)"/>
    <path d="M0 320 Q 60 280 120 320 L 120 360 L 0 360 Z" fill="var(--azul)" opacity="0.85"/>
    <path d="M120 320 Q 180 270 240 320 L 240 360 L 120 360 Z" fill="var(--azul)"/>
    <g>
      <rect x="320" y="330" width="320" height="14" fill="var(--concreto-80)"/>
      <rect x="280" y="344" width="400" height="6" fill="var(--concreto-90)"/>
      <rect x="468" y="180" width="24" height="150" fill="var(--papel-00)" stroke="var(--concreto-90)" stroke-width="1.5"/>
      <rect x="498" y="180" width="24" height="150" fill="var(--papel-00)" stroke="var(--concreto-90)" stroke-width="1.5"/>
      <path d="M360 330 A 50 38 0 0 1 460 330 Z" fill="var(--papel-00)" stroke="var(--concreto-90)" stroke-width="1.5"/>
      <path d="M530 330 A 60 44 0 0 0 650 330 Z" fill="var(--papel-00)" stroke="var(--concreto-90)" stroke-width="1.5"/>
    </g>
    <rect x="120" y="364" width="600" height="56" fill="var(--azul-soft)"/>
    <path d="M0 420 Q 100 400 200 420 T 400 420 L 400 500 L 0 500 Z" fill="var(--verde)"/>
    <path d="M380 420 Q 480 395 580 420 T 800 420 L 800 500 L 380 500 Z" fill="var(--verde)" opacity="0.85"/>
  </svg>
)}

{type === 'pillar' && (
  <svg viewBox="0 0 32 32" width={size} height={size} class={className}>
    {name === 'acervo' && (
      <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square">
        <rect x="4" y="8" width="24" height="20"/>
        <line x1="4" y1="14" x2="28" y2="14"/>
        <line x1="11" y1="14" x2="11" y2="28"/>
        <path d="M4 8 L 16 3 L 28 8" />
      </g>
    )}
    {name === 'exposicoes' && (
      <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square">
        <path d="M4 7 L 16 11 L 28 7 L 28 25 L 16 29 L 4 25 Z"/>
        <line x1="16" y1="11" x2="16" y2="29"/>
        <circle cx="10" cy="17" r="2" fill="currentColor"/>
      </g>
    )}
    {name === 'educacao' && (
      <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square">
        <path d="M16 4 L 28 26 L 4 26 Z"/>
        <line x1="10" y1="16" x2="22" y2="16"/>
      </g>
    )}
    {name === 'cidade' && (
      <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square">
        <line x1="16" y1="6" x2="16" y2="28"/>
        <path d="M10 6 L 22 6 L 22 12 L 10 12 Z" fill="currentColor"/>
        <line x1="6" y1="28" x2="26" y2="28"/>
      </g>
    )}
  </svg>
)}
