---
import CobogoHexagonal from '../patterns/CobogoHexagonal.svelte';
---

<div class="prose-ornament" aria-hidden="true">
  <div class="prose-ornament__line"></div>
  <div class="prose-ornament__icon">
    <CobogoHexagonal client:load tile={false} size={32} color="var(--concreto-60)" density={0.8} />
  </div>
  <div class="prose-ornament__line"></div>
</div>

<style>
  .prose-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 4rem auto;
    max-width: 240px;
  }

  .prose-ornament__line {
    flex: 1;
    height: 1px;
    background: var(--border-strong);
    opacity: 0.2;
  }

  .prose-ornament__icon {
    margin: 0 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
