---
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/docs/DocsSidebar.svelte';
import DocsMobileNav from '../components/docs/DocsMobileNav.svelte';
import PrevNextNav from '../components/docs/PrevNextNav.svelte';
import DocsTOC from '../components/docs/DocsTOC.svelte';
import DocsSearch from '../components/docs/DocsSearch.svelte';
import DocsEditLink from '../components/docs/DocsEditLink.astro';
import DocsThemeToggle from '../components/docs/DocsThemeToggle.svelte';
import { getCollection, type CollectionEntry } from 'astro:content';

const { frontmatter, headings = [], entryId } = Astro.props;

const allDocs = await getCollection('docs', ({ data }) => !data.draft);

// Sort logic: first by section order, then by item order
const sectionOrder = ['intro', 'foundations', 'components', 'patterns', 'recipes'];
allDocs.sort((a: CollectionEntry<'docs'>, b: CollectionEntry<'docs'>) => {
  const sectionA = sectionOrder.indexOf(a.data.section);
  const sectionB = sectionOrder.indexOf(b.data.section);

  if (sectionA !== sectionB) return sectionA - sectionB;
  return a.data.order - b.data.order;
});

const entries = allDocs.map((doc: CollectionEntry<'docs'>) => ({
  slug: doc.slug,
  title: doc.data.title,
  section: doc.data.section,
  order: doc.data.order,
}));

const currentIndex = allDocs.findIndex((doc: CollectionEntry<'docs'>) => doc.data.title === frontmatter.title && doc.data.section === frontmatter.section);

const prev = currentIndex > 0 ? entries[currentIndex - 1] : undefined;
const next = currentIndex < entries.length - 1 ? entries[currentIndex + 1] : undefined;
---

<script>
  const trigger = document.getElementById('mobile-nav-trigger');
  if (trigger) {
    trigger.addEventListener('click', () => {
      // Dispatch a custom event so the Svelte component can listen to it
      window.dispatchEvent(new CustomEvent('toggleMobileNav'));
    });
  }
</script>

<BaseLayout title={`${frontmatter.title} | COBOGÓ Docs`}>
  <header class="docs-header">
    <div class="docs-header-inner">
      <div class="brand">COBOGÓ</div>
      <div class="docs-header-actions">
        <button
          class="hamburger"
          id="mobile-nav-trigger"
          aria-label="Open navigation"
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
        <DocsSearch client:load />
        <DocsThemeToggle client:load />
      </div>
    </div>
  </header>
  <DocsMobileNav client:load entries={entries} currentSlug={Astro.url.pathname} open={false} />

  <div class="docs-grid">
    <DocsSidebar client:load entries={entries} currentSlug={Astro.url.pathname} />
    <article class="prose-cobogo docs-article">
      <h1>{frontmatter.title}</h1>
      {frontmatter.description && <p class="lede">{frontmatter.description}</p>}
      <slot />
      <PrevNextNav prev={prev} next={next} />
      <DocsEditLink entryId={entryId} fallbackSlug={frontmatter.slug || frontmatter.title.toLowerCase().replace(/\s+/g, '-')} />
    </article>
    <DocsTOC headings={headings} client:load />
  </div>
</BaseLayout>

<style>
  .docs-header {
    border-bottom: 1px solid var(--concreto-30, #e0e0e0);
    position: sticky;
    top: 0;
    background: var(--bg, #fff);
    z-index: 40;
  }
  .docs-header-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
  }
  .docs-header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--fg);
    padding: 0.5rem;
  }
  .docs-grid {
    display: grid;
    grid-template-columns: 220px 1fr 200px;
    gap: 3rem;
    max-width: 1240px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }
  .docs-article {
    max-width: 720px;
  }
  .lede {
    font-size: var(--t-lede);
    color: var(--fg-muted);
    margin-bottom: 2rem;
  }
  @media (max-width: 1024px) {
    .docs-grid {
      grid-template-columns: 1fr;
      padding: 2rem 1rem;
    }
    .hamburger {
      display: flex;
    }
  }
</style>
