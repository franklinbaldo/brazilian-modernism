---
import '../styles/global.css';
import DocsThemeToggle from '../components/docs/DocsThemeToggle.svelte';

const { title = "COBOGÓ | Brazilian Modernist Design System" } = Astro.props;
---
<html lang="pt-br">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Fraunces:opsz,wght@9..144,300..900&family=JetBrains+Mono:wght@400;700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body>
    <div class="global-theme-toggle">
      <DocsThemeToggle client:load />
    </div>
    <slot />
  </body>
</html>

<style>
  .global-theme-toggle {
    position: fixed;
    top: 1rem;
    right: 1rem;
    z-index: 10000;
  }
</style>
